<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.geometry.Insets?>

<?import javafx.scene.shape.Line?>
<HBox prefHeight="820.0" prefWidth="800.0"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="media_multitool.ControllerView">

    <VBox alignment="TOP_CENTER"
          prefHeight="820.0"
          prefWidth="170.0"
          spacing="16.0"
          style="-fx-background-color: #1f1f1f;">
        <Label alignment="CENTER"
               prefWidth="140.0"
               style="-fx-font-size: 22px; -fx-font-weight: bold;"
               text="Multitool"
               textFill="WHITE">
            <VBox.margin>
                <Insets top="20.0"/>
            </VBox.margin>
        </Label>

        <Button fx:id="navHomeButton"
                mnemonicParsing="false"
                onAction="#showHomePage"
                prefWidth="140.0"
                text="Home"/>

        <Line startX="85.0"
              endX="85.0" endY="5.0"
              stroke="red" strokeWidth="2.0" />

        <Button fx:id="navConverterImageButton"
                mnemonicParsing="false"
                onAction="#showConverterImagePage"
                prefWidth="140.0"
                text="Converter Image"/>

        <Button fx:id="navConverterVideoButton"
                mnemonicParsing="false"
                onAction="#showConverterVideoPage"
                prefWidth="140.0"
                text="Converter Video"/>

        <Button fx:id="navConverterAudioButton"
                mnemonicParsing="false"
                onAction="#showConverterAudioPage"
                prefWidth="140.0"
                text="Converter Audio"/>

        <Line startX="85.0"
              endX="85.0" endY="5.0"
              stroke="red" strokeWidth="2.0" />

        <Button fx:id="navCompressorImage"
                mnemonicParsing="false"
                onAction="#showCompressorImagePage"
                prefWidth="140.0"
                text="Compressor Image"/>

        <Button fx:id="navCompressorVideo"
                mnemonicParsing="false"
                onAction="#showCompressorVideoPage"
                prefWidth="140.0"
                text="Compressor Video"/>

        <Line startX="85.0"
              endX="85.0" endY="5.0"
              stroke="red" strokeWidth="2.0" />

        <Button fx:id="navInfo"
                mnemonicParsing="false"
                onAction="#showInfoPage"
                prefWidth="140.0"
                text="Info"/>

        <padding>
            <Insets top="8.0" left="14.0" right="14.0" bottom="8.0"/>
        </padding>
    </VBox>

    <StackPane prefHeight="820.0"
               prefWidth="630.0"
               style="-fx-background-color: #2b2b2b;"
               HBox.hgrow="ALWAYS">
        <fx:include fx:id="homeView" source="home-view.fxml"/>
        <fx:include fx:id="converterImagePage" source="converter-image-view.fxml"/>
        <fx:include fx:id="converterVideoPage" source="converter-video-view.fxml"/>
        <fx:include fx:id="converterMP3Page" source="converter-audio-view.fxml"/>
        <fx:include fx:id="compressorImagePage" source="compressor-image-view.fxml"/>
        <fx:include fx:id="compressorVideoPage" source="compressor-video-view.fxml"/>
        <fx:include fx:id="infoPage" source="info-view.fxml"/>
    </StackPane>
</HBox>
