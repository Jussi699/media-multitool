<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.geometry.Insets?>

<HBox prefHeight="600.0" prefWidth="800.0"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="converter.ControllerView">

    <VBox fx:id="leftPane"
          alignment="TOP_CENTER"
          prefHeight="600.0"
          prefWidth="170.0"
          spacing="16.0"
          style="-fx-background-color: #1f1f1f;">
        <Label alignment="CENTER"
               prefWidth="140.0"
               style="-fx-font-size: 22px; -fx-font-weight: bold;"
               text="Converter"
               textFill="WHITE">
            <VBox.margin>
                <Insets top="20.0"/>
            </VBox.margin>
        </Label>

        <Button fx:id="navHomeButton"
                mnemonicParsing="false"
                onAction="#showHomePage"
                prefWidth="140.0"
                text="Home"/>

        <Button fx:id="navConverterImageButton"
                mnemonicParsing="false"
                onAction="#showConverterImagePage"
                prefWidth="140.0"
                text="Image"/>

        <Button fx:id="navConverterVideoButton"
                mnemonicParsing="false"
                onAction="#showConverterVideoPage"
                prefWidth="140.0"
                text="Video"/>

        <Button fx:id="navConverterMP3Button"
                mnemonicParsing="false"
                onAction="#showConverterMP3Page"
                prefWidth="140.0"
                text="MP3"/>
        <padding>
            <Insets left="14.0" right="14.0"/>
        </padding>
    </VBox>

    <StackPane fx:id="rightPane"
               prefHeight="600.0"
               prefWidth="630.0"
               style="-fx-background-color: #2b2b2b;"
               HBox.hgrow="ALWAYS">
        <fx:include fx:id="homeView" source="home-view.fxml"/>
        <fx:include fx:id="converterImagePage" source="converter-image-view.fxml"/>
        <fx:include fx:id="converterVideoPage" source="converter-video-view.fxml"/>
        <fx:include fx:id="converterMP3Page" source="converter-mp3-view.fxml"/>
    </StackPane>
</HBox>