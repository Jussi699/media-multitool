<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.StackPane?>
<VBox fx:id="converterVideoPage"
      alignment="TOP_CENTER"
      prefWidth="630.0"
      spacing="10.0"
      style="-fx-background-color: #4b4b4b;" xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="converter.ConverterVideoViewController">


    <Label fx:id="labelConvertVideo"
           alignment="CENTER"
           prefWidth="260.0"
           style="-fx-font-size: 22px; -fx-font-weight: bold;"
           text="Video Converter"
           textFill="WHITE">
        <VBox.margin>
            <Insets top="10.0"/>
        </VBox.margin>
    </Label>


    <HBox alignment="CENTER" spacing="20.0">
        <Button fx:id="btnSelectVideoFile" mnemonicParsing="false" onAction="#onSelectVideoPressed" prefWidth="170.0" text="Select audio/video" />

        <Button fx:id="btnChoiceDirForSaveVideo" mnemonicParsing="false" onAction="#onSelectOutputDirectoryPressed" prefWidth="170.0" text="Directory for save" />
    </HBox>

    <Label fx:id="labelSelectVideoName"
           alignment="CENTER"
           prefWidth="520.0"
           text="Selected file: none"
           textFill="#f0f0f0"
           wrapText="true"/>

    <HBox alignment="CENTER" spacing="14.0">
        <ToggleButton fx:id="btnToMP4"
                      mnemonicParsing="false"
                      onAction="#onFormatMp4Pressed"
                      prefWidth="90.0"
                      text="to MP4"/>
        <ToggleButton fx:id="btnToAVI"
                      mnemonicParsing="false"
                      onAction="#onFormatAviPressed"
                      prefWidth="90.0"
                      text="to AVI"/>
        <ToggleButton fx:id="btnToMKV"
                      mnemonicParsing="false"
                      onAction="#onFormatMkvPressed"
                      prefWidth="90.0"
                      text="to MKV"/>
        <ToggleButton fx:id="btnToWEBM"
                      mnemonicParsing="false"
                      onAction="#onFormatWEBMPressed"
                      prefWidth="90.0"
                      text="to WEBM"/>

    </HBox>

    <HBox alignment="CENTER" spacing="12.0">
        <Button fx:id="btnSubmitConvert"
                mnemonicParsing="false"
                onAction="#onStartConversionPressed"
                prefWidth="210.0"
                text="Convert and Download"/>
        <Button fx:id="btnReset"
                mnemonicParsing="false"
                onAction="#onResetPressed"
                prefWidth="120.0"
                text="Reset"/>
    </HBox>


    <VBox alignment="CENTER" spacing="10.0">
        <VBox.margin>
            <Insets top="25.0" bottom="5.0" />
        </VBox.margin>
        <ProgressBar fx:id="progressBarConvert"
                     prefWidth="200.0"
                     minHeight="15"
                     progress="0.0"/>

        <StackPane prefHeight="8.0">
            <Label fx:id="labelSuccessConvert"
                   alignment="CENTER"
                   prefWidth="400.0"
                   textFill="#32CD32"
                   text="Convert has been success!">
                <style>-fx-font-weight: bold;</style>
            </Label>
        </StackPane>
        <VBox.margin>
            <Insets bottom="0" />
        </VBox.margin>
    </VBox>

    <Region VBox.vgrow="ALWAYS"/>

    <padding>
        <Insets left="18.0" right="18.0" bottom="18.0"/>
    </padding>
</VBox>
