<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17.0.12"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="media_multitool.ConverterAudioController">
    <VBox alignment="TOP_CENTER"
          prefHeight="820.0"
          prefWidth="630.0"
          spacing="12.0"
          style="-fx-background-color: #4b4b4b;">


        <Label alignment="CENTER" prefWidth="320.0"
               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: RED"
               text="Audio Converter">
            <VBox.margin>
                <Insets top="8.0"/>
            </VBox.margin>
        </Label>

        <HBox alignment="CENTER" spacing="20.0">
            <Button fx:id="btnSelectAudioVideoFile" mnemonicParsing="false" onAction="#onSelectAudioVideoPressed" prefWidth="180.0" text="Select audio/video" />

            <Button fx:id="btnChoiceDirForSaveMP3" mnemonicParsing="false" onAction="#onSelectOutputDirectoryPressed" prefWidth="180.0" text="Directory for save" />
        </HBox>


        <HBox alignment="CENTER" spacing="16.0">
            <ToggleButton fx:id="btnToMP3" mnemonicParsing="false"
                          onAction="#onFormatMp3Pressed"
                          prefWidth="100.0"
                          text="to MP3"/>

            <ToggleButton fx:id="btnToAAC" mnemonicParsing="false"
                          onAction="#onFormatAACPressed"
                          prefWidth="100.0"
                          text="to AAC"/>

            <ToggleButton fx:id="btnToOggVorbis" mnemonicParsing="false"
                          onAction="#onFormatOggPressed"
                          prefWidth="100.0"
                          text="to OGG"/>

            <ToggleButton fx:id="btnToOPUS" mnemonicParsing="false"
                          onAction="#onFormatOpusPressed"
                          prefWidth="100.0"
                          text="to OPUS"/>
        </HBox>

        <HBox alignment="CENTER" spacing="16.0">
            <ToggleButton fx:id="btnToFLAC" mnemonicParsing="false"
                          onAction="#onFormatFlacPressed"
                          prefWidth="100.0"
                          text="to FLAC"/>

            <ToggleButton fx:id="btnToALAC" mnemonicParsing="false"
                          onAction="#onFormatAlacPressed"
                          prefWidth="100.0"
                          text="to ALAC"/>

            <ToggleButton fx:id="btnToWAV" mnemonicParsing="false"
                          onAction="#onFormatWAvPressed"
                          prefWidth="100.0"
                          text="to WAV"/>

            <ToggleButton fx:id="btnToAIFF" mnemonicParsing="false"
                          onAction="#onFormatAiffPressed"
                          prefWidth="100.0"
                          text="to AIFF"/>
        </HBox>

        <HBox alignment="CENTER" spacing="16.0">
            <ComboBox fx:id="comboBoxChoiceBitRate" onAction="#onChoiceBitRate" prefWidth="140.0" />

            <ComboBox fx:id="comboBoxChoiceChannels" onAction="#onChoiceChannels" prefWidth="140.0" />

            <ComboBox fx:id="comboBoxChoiceSamplingRate" onAction="#onChoiceSamplingRate" prefWidth="140.0" />
        </HBox>

        <StackPane>
            <VBox.margin>
                <Insets top="4.0"/>
            </VBox.margin>
            <HBox alignment="CENTER" spacing="10.0">
                <Button fx:id="btnSubmitConvert"
                        mnemonicParsing="false"
                        onAction="#onStartConversionPressed"
                        prefWidth="220.0" text="Convert and Download" />

                <Button mnemonicParsing="false"
                        onAction="#onCancelConversation"
                        prefWidth="220.0" text="Cancel Conversion" />
            </HBox>
        </StackPane>

        <VBox alignment="CENTER" spacing="8.0">
            <VBox.margin>
                <Insets top="2.0" />
            </VBox.margin>
            <ProgressBar fx:id="progressBarConvert"
                         prefWidth="460.0"
                         minHeight="16.0"
                         progress="0.0"/>

            <StackPane minHeight="24.0" prefHeight="24.0">
                <Label fx:id="labelSuccessConvert"
                       styleClass="labelSuccess"
                       alignment="CENTER"
                       prefWidth="560.0"
                       textFill="#32CD32"
                       text="Convert has been success!" />
            </StackPane>
        </VBox>


        <StackPane fx:id="dropZone" styleClass="drop-zone"
                   onDragOver="#handleDragOver"
                   onDragDropped="#handleDragDropped"
                   minHeight="215.0"
                   prefHeight="215.0"
                   prefWidth="560.0"
                   VBox.vgrow="ALWAYS"
                   style="-fx-border-color: white; -fx-border-style: dashed; -fx-border-width: 2; -fx-border-radius: 10;">
            <VBox.margin>
                <Insets top="2.0" />
            </VBox.margin>
            <Label fx:id="textDragZone" text="Drag files here" textFill="WHITE" style="-fx-font-size: 18px;" />
        </StackPane>

        <VBox alignment="CENTER" spacing="6.0">
            <Label fx:id="labelSelectAudioFile" styleClass="labelSelect"
                   alignment="CENTER"
                   prefWidth="600.0"
                   minHeight="18.0"
                   text="none"
                   textFill="RED"
                   wrapText="true"/>

            <Button mnemonicParsing="false"
                    onAction="#onResetPressed"
                    prefWidth="240.0" text="Reset" />
        </VBox>

        <padding>
            <Insets top="8.0" bottom="16.0" left="16.0" right="16.0" />
        </padding>
    </VBox>

    <Button text="?"
            onAction="#showInfo"
            styleClass="info-button"
            StackPane.alignment="TOP_LEFT">
        <StackPane.margin>
            <Insets top="10.0" left="10.0"/>
        </StackPane.margin>
    </Button>
</StackPane>
