<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>

<AnchorPane fx:id="AnchorPane" prefHeight="600.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"  fx:controller="converter.Controller">

    <children>
        <Pane fx:id="mainPane" prefHeight="600.0" prefWidth="1000.0" style="-fx-background-color: #2b2b2b;">

            <children>
                <Pane prefHeight="600.0" prefWidth="300.0" style="-fx-background-color: #4b4b4b;">
                    <children>
                        <Button fx:id="btnSelectPhotoFile" layoutX="117.0" layoutY="50.0" mnemonicParsing="false" text="Select file" onMouseClicked="#ActionBtnSelectFile"/>
                        <Label fx:id="LabelConvertPhoto" layoutX="113.0" layoutY="14.0" text="Convert Photo" textFill="RED" />
                        <ToggleButton fx:id="btnToPNG" layoutX="44.0" layoutY="138.0" mnemonicParsing="false" prefHeight="25.0" prefWidth="67.0" text="to PNG" onMouseClicked="#ActionBtnToPNG"/>
                        <ToggleButton fx:id="btnToJPEG" layoutX="122.0" layoutY="138.0" mnemonicParsing="false" prefHeight="25.0" prefWidth="67.0" text="to JPEG" onMouseClicked="#ActionBtnToJPEG" />
                        <ToggleButton fx:id="btnToICO" layoutX="205.0" layoutY="138.0" mnemonicParsing="false" prefHeight="25.0" prefWidth="67.0" text="to ICO" onMouseClicked="#ActionBtnToICO"/>
                        <Button fx:id="btnSubmitConvert" layoutX="81.0" layoutY="214.0" mnemonicParsing="false" prefHeight="25.0" prefWidth="150.0" text="Convert" onMouseClicked="#SubmitConvertAndDownload"/>
                        <Button fx:id="btnChoiceDirForSaveImage" layoutX="81.0" layoutY="250.0" mnemonicParsing="false" prefHeight="25.0" prefWidth="150.0" text="btnChoiceDirForSaveImage" onMouseClicked="#btnChoiceDirForSaveImage"/>
                        <ProgressBar fx:id="ProgressBarCompleteConvert" layoutX="56.0" layoutY="291.0" prefWidth="200.0" progress="0.0" />
<!--                        <Button fx:id="btnDownloadImage" layoutX="124.0" layoutY="360.0" mnemonicParsing="false" text="Button" />-->
                    </children>
                </Pane>
                <Pane layoutX="700.0" prefHeight="600.0" prefWidth="300.0" style="-fx-background-color: #4b4b4b;" />

            </children>
        </Pane>
    </children>
</AnchorPane>
