<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Group?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<VBox fx:id="converterImagePage"
      alignment="TOP_CENTER"
      prefHeight="600.0"
      prefWidth="630.0"
      spacing="20.0"
      style="-fx-background-color: #4b4b4b;"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="converter.ConverterImageViewController">

        <Label fx:id="LabelConvertPhoto"
               alignment="CENTER"
               prefWidth="200.0"
               text="Convert Photo"
               textFill="RED">
            <VBox.margin>
                <Insets top="8.0" />
            </VBox.margin>
        </Label>

        <HBox alignment="CENTER" spacing="20.0">
                <Button fx:id="btnSelectPhotoFile"
                        mnemonicParsing="false"
                        onAction="#ActionBtnSelectFile"
                        prefWidth="150.0"
                        text="Select image" />

                <Button fx:id="btnChoiceDirForSaveImage"
                        mnemonicParsing="false"
                        onAction="#btnChoiceDirForSaveImage"
                        prefWidth="150.0"
                        text="Directory for save" />
        </HBox>

        <HBox alignment="CENTER" spacing="20.0" translateY="5.0">
                <ToggleButton fx:id="btnToPNG"
                              mnemonicParsing="false"
                              onAction="#ActionBtnToPNG"
                              prefWidth="85.0"
                              text="to PNG" />

                <ToggleButton fx:id="btnToJPEG"
                              mnemonicParsing="false"
                              onAction="#ActionBtnToJPEG"
                              prefWidth="85.0"
                              text="to JPEG" />

                <ToggleButton fx:id="btnToWEBM"
                              mnemonicParsing="false"
                              onAction="#ActionBtnToWEBM"
                              prefWidth="85.0"
                              text="to WEBP" />

                <ComboBox fx:id="comboBoxIcoSize"
                          onAction="#onChoiceIcoSize"
                          prefWidth="85.0"/>
        </HBox>

        <StackPane translateY="10.0">
                <VBox alignment="CENTER" spacing="10.0">
                        <Button fx:id="btnSubmitConvert"
                                mnemonicParsing="false"
                                onAction="#SubmitConvertAndDownload"
                                prefWidth="210.0"
                                text="Convert and Download" />
                </VBox>

                <Label fx:id="labelSuccessConvert"
                       alignment="CENTER"
                       prefWidth="280.0"
                       textFill="#32CD32"
                       visible="false"
                       managed="false"
                       StackPane.alignment="BOTTOM_CENTER"
                       translateY="20.0" />
        </StackPane>

        <ScrollPane fx:id="scrollPanePhoto"
                    fitToHeight="true"
                    fitToWidth="true"
                    pannable="true"
                    prefWidth="590.0"
                    VBox.vgrow="ALWAYS">
            <VBox.margin>
                <Insets top="20.0" />
            </VBox.margin>
                <StackPane fx:id="imageContainer"
                           minHeight="200.0"
                           minWidth="560.0">
                        <Group>
                                <ImageView fx:id="imageViewPhoto"
                                           fitHeight="260.0"
                                           fitWidth="560.0"
                                           pickOnBounds="true"
                                           preserveRatio="true" />
                        </Group>
                </StackPane>
        </ScrollPane>

        <VBox alignment="CENTER" spacing="8.0">
                <HBox alignment="CENTER" spacing="10.0">
                        <Label fx:id="LabelMinus" text="-" textFill="RED" />
                        <Slider fx:id="imageScaleSlider"
                                min="1.0"
                                max="3.0"
                                value="1.0"
                                prefWidth="260.0" />
                        <Label fx:id="LabelPlus" text="+" textFill="RED" />
                </HBox>

                <Label fx:id="labelSelectImageName"
                       alignment="CENTER"
                       prefWidth="400.0"
                       text="none"
                       textFill="RED" />

                <Button mnemonicParsing="false"
                        fx:id="btnReset"
                        onAction="#isPressedReset"
                        prefWidth="220.0"
                        text="Reset" />
        </VBox>

    <padding>
        <Insets left="16.0" right="16.0" bottom="16.0" />
    </padding>
</VBox>