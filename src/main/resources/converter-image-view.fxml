<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Group?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<VBox alignment="TOP_CENTER"
      prefHeight="600.0"
      prefWidth="630.0"
      spacing="20.0"
      style="-fx-background-color: #4b4b4b;"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="converter.ConverterImageViewController">

    <Label alignment="CENTER"
           prefWidth="200.0"
           text="Convert Photo"
           textFill="RED"
           style="-fx-font-size: 22px; -fx-font-weight: bold;">
        <VBox.margin>
            <Insets top="8.0"/>
        </VBox.margin>
    </Label>

    <HBox alignment="CENTER" spacing="20.0">
        <Button fx:id="btnSelectPhotoFile"
                mnemonicParsing="false"
                onAction="#ActionBtnSelectFile"
                prefWidth="150.0"
                text="Select image"/>

        <Button fx:id="btnChoiceDirForSaveImage"
                mnemonicParsing="false"
                onAction="#btnChoiceDirForSaveImage"
                prefWidth="150.0"
                text="Directory for save"/>
    </HBox>

    <HBox alignment="CENTER" spacing="20.0" translateY="5.0">
        <ToggleButton fx:id="btnToPNG"
                      mnemonicParsing="false"
                      onAction="#ActionBtnToPNG"
                      prefWidth="85.0"
                      text="to PNG"/>

        <ToggleButton fx:id="btnToJPEG"
                      mnemonicParsing="false"
                      onAction="#ActionBtnToJPEG"
                      prefWidth="85.0"
                      text="to JPEG"/>

        <ToggleButton fx:id="btnToWEBM"
                      mnemonicParsing="false"
                      onAction="#ActionBtnToWEBM"
                      prefWidth="85.0"
                      text="to WEBP"/>


        <ComboBox fx:id="comboBoxIcoSize"
                  onAction="#onChoiceIcoSize"
                  prefWidth="85.0"/>
    </HBox>

    <HBox alignment="CENTER" spacing="20.0" translateY="5.0">
        <ToggleButton fx:id="btnToTIFF"
                      mnemonicParsing="false"
                      onAction="#ActionBtnToTIFF"
                      prefWidth="85.0"
                      text="to TIFF"/>

        <ToggleButton fx:id="btnToBMP"
                      mnemonicParsing="false"
                      onAction="#ActionBtnToBMP"
                      prefWidth="85.0"
                      text="to BMP"/>

        <ToggleButton fx:id="btnToPPM"
                      mnemonicParsing="false"
                      onAction="#ActionBtnToPPM"
                      prefWidth="85.0"
                      text="to PPM"/>

        <ToggleButton fx:id="btnToPGM"
                      mnemonicParsing="false"
                      onAction="#ActionBtnToPGM"
                      prefWidth="85.0"
                      text="to PGM"/>

        <ToggleButton fx:id="btnToPAM"
                      mnemonicParsing="false"
                      onAction="#ActionBtnToPAM"
                      prefWidth="85.0"
                      text="to PAM"/>

        <ToggleButton fx:id="btnToSVG"
                      mnemonicParsing="false"
                      onAction="#ActionBtnToSVG"
                      prefWidth="85.0"
                      text="to SVG"/>
    </HBox>

    <StackPane translateY="10.0">
        <VBox alignment="CENTER" spacing="10.0">
            <Button mnemonicParsing="false"
                    onAction="#SubmitConvertAndDownload"
                    prefWidth="210.0"
                    text="Convert and Download"/>
        </VBox>

        <Label fx:id="labelSuccessConvert"
               alignment="CENTER"
               prefWidth="280.0"
               textFill="#32CD32"
               visible="false"
               managed="true"
               StackPane.alignment="BOTTOM_CENTER" translateY="20"/>
    </StackPane>

    <ScrollPane fx:id="scrollPanePhoto"
                fitToHeight="true"
                fitToWidth="true"
                pannable="true"
                prefWidth="590.0"
                VBox.vgrow="ALWAYS">
        <VBox.margin>
            <Insets top="20.0"/>
        </VBox.margin>
        <StackPane fx:id="imageContainer"
                   minHeight="200.0"
                   minWidth="560.0">
            <Group>
                <ImageView fx:id="imageViewPhoto"
                           fitHeight="260.0"
                           fitWidth="560.0"
                           pickOnBounds="true"
                           preserveRatio="true"/>
            </Group>
        </StackPane>
    </ScrollPane>

    <VBox alignment="CENTER" spacing="8.0">
        <HBox alignment="CENTER" spacing="10.0">
            <Label text="-" textFill="RED"/>
            <Slider fx:id="imageScaleSlider"
                    min="1.0"
                    max="3.0"
                    value="1.0"
                    prefWidth="260.0"/>
            <Label text="+" textFill="RED"/>
        </HBox>

        <Label fx:id="labelSelectImageName"
               alignment="CENTER"
               prefWidth="600.0"
               text="none"
               textFill="RED"/>

        <Button mnemonicParsing="false"
                onAction="#isPressedReset"
                prefWidth="220.0"
                text="Reset"/>
    </VBox>

    <padding>
        <Insets left="16.0" right="16.0" bottom="16.0"/>
    </padding>
</VBox>