<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Group?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/25"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="media_multitool.CompressorImageController">
    <VBox alignment="TOP_CENTER"
          prefHeight="820.0"
          prefWidth="630.0"
          spacing="12.0"
          style="-fx-background-color: #4b4b4b;">

        <Label alignment="CENTER"
               prefWidth="320.0"
               text="Compressor Image"
               textFill="RED"
               style="-fx-font-size: 22px; -fx-font-weight: bold;">
            <VBox.margin>
                <Insets top="8.0"/>
            </VBox.margin>
        </Label>

        <HBox alignment="CENTER" spacing="20.0">
            <Button fx:id="btnSelectPhotoFile"
                    mnemonicParsing="false"
                    onAction="#ActionBtnSelectFile"
                    prefWidth="180.0"
                    text="Select image"/>

            <Button fx:id="btnChoiceDirForSaveImage"
                    mnemonicParsing="false"
                    onAction="#btnChoiceDirForSaveImage"
                    prefWidth="180.0"
                    text="Directory for save"/>
        </HBox>

        <HBox alignment="CENTER" spacing="20.0">
            <ComboBox fx:id="comboBoxScaleImage"
                      onAction="#onChoiceScaleImage"
                      prefWidth="140.0"/>

            <ComboBox fx:id="comboBoxOutputQuality"
                      onAction="#onChoiceOutputQuality"
                      prefWidth="140.0"/>
        </HBox>

        <VBox alignment="CENTER" spacing="8.0">
            <Label fx:id="labelSuccessConvert" styleClass="labelSuccess"
                   alignment="CENTER"
                   prefWidth="560.0"
                   minHeight="20.0"
                   prefHeight="20.0"
                   visible="false"
                   managed="true"
                   text="Compression status"
                   textFill="#32CD32"
                   wrapText="true"/>

            <Button mnemonicParsing="false"
                    onAction="#submitCompressAndDownload"
                    prefWidth="240.0"
                    text="Convert and Download" />
        </VBox>

        <HBox alignment="CENTER" spacing="12.0" VBox.vgrow="ALWAYS">
            <VBox alignment="CENTER" spacing="8.0">
                <Label text="Original" textFill="RED"/>
                <ScrollPane fx:id="scrollPanePhotoOriginal"
                            fitToHeight="true"
                            fitToWidth="true"
                            pannable="true"
                            prefWidth="270.0"
                            prefHeight="290.0"
                            VBox.vgrow="ALWAYS">
                    <StackPane fx:id="imageContainerOriginal"
                               minHeight="310.0"
                               minWidth="250.0">
                        <Group>
                            <ImageView fx:id="imageViewPhotoOriginal"
                                       fitHeight="310.0"
                                       fitWidth="250.0"
                                       pickOnBounds="true"
                                       preserveRatio="true"/>
                        </Group>
                    </StackPane>
                </ScrollPane>
            </VBox>

            <VBox alignment="CENTER" spacing="8.0" >
                <Label text="Compressed" textFill="RED"/>
                <ScrollPane fx:id="scrollPanePhotoCompressed"
                            fitToHeight="true"
                            fitToWidth="true"
                            pannable="true"
                            prefWidth="270.0"
                            prefHeight="290.0"
                            VBox.vgrow="ALWAYS">
                    <StackPane fx:id="imageContainerCompressed"
                               minHeight="310.0"
                               minWidth="250.0">
                        <Group>
                            <ImageView fx:id="imageViewPhotoCompressed"
                                       fitHeight="310.0"
                                       fitWidth="250.0"
                                       pickOnBounds="true"
                                       preserveRatio="true"/>
                        </Group>
                    </StackPane>
                </ScrollPane>
            </VBox>
        </HBox>

        <VBox alignment="CENTER" spacing="4.0">
            <Label fx:id="labelSelectImageName" styleClass="labelSelect"
                   alignment="CENTER"
                   prefWidth="600.0"
                   minHeight="18.0"
                   text="Selected image file: none"
                   textFill="RED"
                   wrapText="true"/>

            <Button mnemonicParsing="false"
                    onAction="#onResetPressed"
                    prefWidth="240.0"
                    text="Reset"/>
        </VBox>

        <padding>
            <Insets top="8.0" left="16.0" right="16.0" bottom="16.0"/>
        </padding>
    </VBox>

    <Button text="?"
            onAction="#showInfo"
            styleClass="info-button"
            StackPane.alignment="TOP_LEFT">
        <StackPane.margin>
            <Insets top="10.0" left="10.0"/>
        </StackPane.margin>
    </Button>
</StackPane>
