<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/25"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="media_multitool.compressors.CompressorImageController">
    <VBox alignment="TOP_CENTER"
          maxWidth="Infinity"
          maxHeight="Infinity"
          spacing="12.0"
          style="-fx-background-color: #4b4b4b;">

        <Label styleClass="main-label-name-page"
               text="Compressor Image">
            <VBox.margin>
                <Insets top="8.0"/>
            </VBox.margin>
        </Label>

        <HBox alignment="CENTER" spacing="20.0">
            <Button fx:id="btnSelectImageFile"
                    mnemonicParsing="false"
                    onAction="#ActionBtnSelectFile"
                    prefWidth="180.0"
                    text="Select image file"/>

            <Button fx:id="btnChoiceDirForSaveImage"
                    mnemonicParsing="false"
                    onAction="#btnChoiceDirForSaveImage"
                    prefWidth="180.0"
                    text="Directory for save">
                <tooltip>
                    <Tooltip text="Default directory: Desktop" />
                </tooltip>
            </Button>
        </HBox>

        <HBox alignment="CENTER" spacing="20.0">
            <ComboBox fx:id="comboBoxScaleImage"
                      onAction="#onChoiceScaleImage"
                      prefWidth="140.0"/>

            <ComboBox fx:id="comboBoxOutputQuality"
                      onAction="#onChoiceOutputQuality"
                      prefWidth="140.0"/>
        </HBox>

        <VBox alignment="CENTER" spacing="8.0">
            <Label fx:id="labelSuccess" styleClass="labelSuccess"
                   visible="false"
                   text="Compression status"
                   wrapText="true"/>

            <Button fx:id="btnSubmit" mnemonicParsing="false"
                    onAction="#submitCompressAndDownload"
                    prefWidth="240.0"
                    text="Convert and Download" />
        </VBox>

        <VBox spacing="12.0" VBox.vgrow="ALWAYS">
            <padding>
                <Insets left="4.0" right="4.0" />
            </padding>
            <VBox.margin>
                <Insets top="2.0" />
            </VBox.margin>

            <StackPane fx:id="previewContainer" styleClass="preview-container" VBox.vgrow="ALWAYS" minWidth="200">
                <ImageView fx:id="imageViewPreview" preserveRatio="true" />
                <Label fx:id="labelPreviewPlaceholder" text="Preview"/>
            </StackPane>

            <HBox spacing="5.0" VBox.vgrow="ALWAYS">
                <StackPane fx:id="dropZone" styleClass="drop-zone" HBox.hgrow="ALWAYS" maxHeight="Infinity">
                    <Label fx:id="textDragZone" styleClass="label-drag-zone" text="Drag files here"  />
                </StackPane>
            </HBox>
        </VBox>

        <VBox alignment="CENTER" spacing="6.0">
            <Label fx:id="labelSelectFile" styleClass="labelSelect"
                   text="Selected file: none" />

            <Button fx:id="btnReset" styleClass="btn-reset"
                    mnemonicParsing="false"
                    onAction="#isPressedReset"
                    text="Reset"/>
        </VBox>

        <padding>
            <Insets top="8.0" left="16.0" right="16.0" bottom="16.0"/>
        </padding>
    </VBox>

    <Button text="?"
            onAction="#showInfo"
            styleClass="info-button"
            StackPane.alignment="TOP_LEFT">
        <StackPane.margin>
            <Insets top="10.0" left="10.0"/>
        </StackPane.margin>
    </Button>
</StackPane>
