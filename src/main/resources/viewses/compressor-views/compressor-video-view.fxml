<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/25"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="media_multitool.compressors.CompressorVideoController">
    <VBox alignment="TOP_CENTER"
          maxWidth="Infinity"
          maxHeight="Infinity"
          spacing="12.0"
          style="-fx-background-color: #4b4b4b;">

        <Label styleClass="main-label-name-page"
               text="Compressor Video">
            <VBox.margin>
                <Insets top="8.0"/>
            </VBox.margin>
        </Label>

        <HBox alignment="CENTER" spacing="20.0">
            <Button fx:id="btnSelectFile"
                    mnemonicParsing="false"
                    onAction="#onActionBtnSelectVideoFile"
                    prefWidth="180.0"
                    text="Select video file"/>

            <Button fx:id="btnChoiceDirForSaveFile"
                    mnemonicParsing="false"
                    onAction="#onActionChoiceDirForSaveFile"
                    prefWidth="180.0"
                    text="Directory for save">
                <tooltip>
                    <Tooltip text="Default directory: Desktop" />
                </tooltip>
            </Button>
        </HBox>

        <HBox alignment="CENTER" spacing="20.0">
            <ToggleButton prefWidth="80" onAction="#onActionSelectPreset" fx:id="btnBasicCompress" text="Basic">
                <tooltip>
                    <Tooltip text="Balanced size and quality" />
                </tooltip>
            </ToggleButton>

            <ToggleButton prefWidth="80" onAction="#onActionSelectPreset" fx:id="btnStrongCompress" text="Strong">
                <tooltip>
                    <Tooltip text="Smallest size, lowest quality" />
                </tooltip>
            </ToggleButton>

            <ToggleButton prefWidth="80" onAction="#onActionSelectPreset" fx:id="btnSuperCompress" text="Super">
                <tooltip>
                    <Tooltip text="Small size, high quality" />
                </tooltip>
            </ToggleButton>
        </HBox>

        <HBox alignment="CENTER" spacing="20.0" minHeight="12.0" prefHeight="12.0">
            <Button fx:id="btnCompress" mnemonicParsing="false"
                    onAction="#submitAndDownload"
                    prefWidth="240.0"
                    text="Convert and Download" >
                <tooltip>
                    <Tooltip text="Compression may take a long time, especially for large files." />
                </tooltip>
            </Button>

            <Button fx:id="btnCancelConversion"
                    mnemonicParsing="false"
                    onAction="#onActionCancelOperation"
                    prefWidth="220.0" text="Cancel Compress" />

            <CheckBox fx:id="chkUseGPU"
                      onAction="#onGPUSelected"
                      mnemonicParsing="false" text="Use GPU" textFill="red">
                <tooltip>
                    <Tooltip text="Use NVENC (NVIDIA GPU) if available (may significantly speed up encoding)." />
                </tooltip>
            </CheckBox>
        </HBox>

        <VBox alignment="CENTER" spacing="8.0">
            <Label fx:id="labelSuccess" styleClass="labelSuccess"
                   visible="false"
                   text="Compression was successful!"/>

            <ProgressBar fx:id="progressBar"
                         prefWidth="460.0"
                         minHeight="20.0"
                         progress="0.0"/>
        </VBox>

        <StackPane fx:id="dropZone" styleClass="drop-zone-solo"
                   VBox.vgrow="ALWAYS">
            <VBox.margin>
                <Insets top="2.0" />
            </VBox.margin>
            <Label fx:id="textDragZone" text="Drag files here" textFill="WHITE" styleClass="label-drag-zone" />
        </StackPane>

        <VBox alignment="CENTER" spacing="6.0">
            <Label fx:id="labelSelectFile"
                   styleClass="labelSelect"
                   text="Selected video file: none"/>

            <Button fx:id="btnReset"
                    mnemonicParsing="false"
                    onAction="#isPressedReset"
                    prefWidth="240.0"
                    text="Reset"/>
        </VBox>

        <padding>
            <Insets top="8.0" left="16.0" right="16.0" bottom="16.0"/>
        </padding>
    </VBox>

    <Button text="?"
            onAction="#showInfo"
            styleClass="info-button"
            StackPane.alignment="TOP_LEFT">
        <StackPane.margin>
            <Insets top="10.0" left="10.0"/>
        </StackPane.margin>
    </Button>
</StackPane>
