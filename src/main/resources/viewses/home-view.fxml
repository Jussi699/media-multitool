<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>

<StackPane xmlns="http://javafx.com/javafx/25"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="media_multitool.HomeViewController">

    <VBox alignment="TOP_CENTER"
          spacing="18.0"
          style="-fx-background-color: #343434;">

        <Label alignment="CENTER"
               style="-fx-font-size: 30px; -fx-font-weight: bold;"
               text="Media multitool"
               textFill="RED" />

        <Label alignment="CENTER"
               style="-fx-font-size: 16px;"
               text="Select the type of media_multitool you want to use:"
               textFill="#d6d6d6"
               wrapText="true" />

        <VBox spacing="18.0" style="-fx-background-color: #343434;" VBox.vgrow="ALWAYS">

            <Label text="Converter" textFill="RED"/>
            <Separator styleClass="home-separator"/>

            <HBox styleClass="hbox-home-page">
                <Button mnemonicParsing="false"
                        onAction="#onOpenImageConverterPressed"
                        prefWidth="160.0"
                        text="Converter Image"/>
                <Button mnemonicParsing="false"
                        onAction="#onOpenVideoConverterPressed"
                        prefWidth="160.0"
                        text="Converter Video"/>
                <Button mnemonicParsing="false"
                        onAction="#onOpenMP3ConverterPressed"
                        prefWidth="160.0"
                        text="Converter Audio"/>
            </HBox>

            <Label text="Compressors" textFill="RED"/>
            <Separator styleClass="home-separator"/>

            <HBox styleClass="hbox-home-page">
                <Button mnemonicParsing="false"
                        onAction="#onOpenImageCompressorPressed"
                        prefWidth="160.0"
                        text="Compressor Image"/>
                <Button mnemonicParsing="false"
                        onAction="#onOpenVideoCompressorPressed"
                        prefWidth="160.0"
                        text="Compressor Video"/>

                <Button mnemonicParsing="false"
                        onAction="#onOpenCompressorPdfPressed"
                        prefWidth="160.0"
                        text="Compressor PDF"/>
            </HBox>

            <Label text="Image Tools" textFill="RED"/>
            <Separator styleClass="home-separator"/>

            <HBox styleClass="hbox-home-page">
                <Button mnemonicParsing="false"
                        onAction="#onOpenNegativeImagePressed"
                        prefWidth="160.0"
                        text="Negative Image"/>

                <Button mnemonicParsing="false"
                        onAction="#onOpenTurnImagePressed"
                        prefWidth="160.0"
                        text="Turn Image"/>

                <Button mnemonicParsing="false"
                        onAction="#onOpenLightenImagePressed"
                        prefWidth="160.0"
                        text="Lighten Image"/>

                <Button mnemonicParsing="false"
                        onAction="#onOpenDarkenImagePressed"
                        prefWidth="160.0"
                        text="Darken Image"/>
            </HBox>

            <HBox styleClass="hbox-home-page">
                <Button mnemonicParsing="false"
                        onAction="#onOpenColorizeImagePressed"
                        prefWidth="160.0"
                        text="Colorize Image"/>

                <Button mnemonicParsing="false"
                        onAction="#onOpenBlackAndWhiteImagePressed"
                        prefWidth="160.0"
                        text="Black-White Image"/>

                <Button mnemonicParsing="false"
                        onAction="#onOpenBlurImagePressed"
                        prefWidth="160.0"
                        text="Blur Image"/>

                <Button mnemonicParsing="false"
                        onAction="#onOpenFindPixelPressed"
                        prefWidth="160.0"
                        text="Find Pixel"/>
            </HBox>

            <HBox styleClass="hbox-home-page">
                <Button mnemonicParsing="false"
                        onAction="#onOpenCropImagePressed"
                        prefWidth="160.0"
                        text="Crop Image"/>

                <Button mnemonicParsing="false"
                        onAction="#onOpenCropImagePressed"
                        prefWidth="160.0"
                        text="Crop Image"/>

                <Button mnemonicParsing="false"
                        onAction="#onOpenColorReplaceInImagePressed"
                        prefWidth="160.0"
                        text="Color Replace In Image"/>
            </HBox>

            <Label text="PDF Tools" textFill="RED"/>
            <Separator styleClass="home-separator"/>

            <HBox styleClass="hbox-home-page">
                <Button mnemonicParsing="false"
                        onAction="#onOpenImageToPdfPressed"
                        prefWidth="160.0"
                        text="Image To PDF"/>

                <Button mnemonicParsing="false"
                        onAction="#onOpenPdfToImagePressed"
                        prefWidth="160.0"
                        text="PDF To Image"/>

                <Button mnemonicParsing="false"
                        onAction="#onOpenImagesToPdfPressed"
                        prefWidth="160.0"
                        text="Images To PDF (merge)"/>

                <Button mnemonicParsing="false"
                        onAction="#onOpenProtectPdfPressed"
                        prefWidth="160.0"
                        text="Protect PDF"/>
            </HBox>

            <HBox styleClass="hbox-home-page">
                <Button mnemonicParsing="false"
                        onAction="#onOpenUnlockPdfPressed"
                        prefWidth="160.0"
                        text="Unlock PDF"/>

                <Button mnemonicParsing="false"
                        onAction="#onOpenRemovePagesPdfPressed"
                        prefWidth="160.0"
                        text="Remove Pages PDF"/>

                <Button mnemonicParsing="false"
                        onAction="#onOpenCompressorPdfPressed"
                        prefWidth="160.0"
                        text="Compressor PDF"/>

                <Button mnemonicParsing="false"
                        onAction="#onOpenMergePdfPressed"
                        prefWidth="160.0"
                        text="Merge PDF"/>
            </HBox>

            <HBox styleClass="hbox-home-page">
                <Button mnemonicParsing="false"
                        onAction="#onOpenSplitPdfPressed"
                        prefWidth="160.0"
                        text="Split PDF"/>
            </HBox>

            <Label text="Audio Tag Editor" textFill="RED"/>
            <Separator styleClass="home-separator"/>

            <HBox styleClass="hbox-home-page">
                <Button mnemonicParsing="false"
                        onAction="#onOpenEditorAudioTagPressed"
                        prefWidth="160.0"
                        text="Audio Tag Editor"/>
            </HBox>

            <Button mnemonicParsing="false"
                    onAction="#onOpenInfoPressed"
                    prefWidth="160.0"
                    text="Info"/>
        </VBox>

        <padding>
            <Insets left="40.0" right="40.0" top="40.0" bottom="40.0" />
        </padding>
    </VBox>

    <Button text="?"
            onAction="#showInfo"
            styleClass="info-button"
            StackPane.alignment="TOP_LEFT">
        <StackPane.margin>
            <Insets top="10.0" left="10.0"/>
        </StackPane.margin>
    </Button>
</StackPane>
