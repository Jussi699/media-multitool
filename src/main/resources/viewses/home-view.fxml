<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>

<StackPane xmlns="http://javafx.com/javafx/25"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="media_multitool.HomeViewController">

    <VBox alignment="TOP_CENTER"
          style="-fx-background-color: linear-gradient(to bottom, #1a1a1a, #2d2d2d);">

        <VBox alignment="CENTER" spacing="8.0" style="-fx-padding: 30 40 20 40; -fx-background-color: linear-gradient(to bottom, #2d2d2d, #1a1a1a);">
            <Label alignment="CENTER"
                   style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: linear-gradient(to right, #32CD32, #00FF00);"
                   text="Media Multitool" />

            <Label alignment="CENTER"
                   style="-fx-font-size: 14px; -fx-text-fill: #b0b0b0;"
                   text="Professional media conversion and editing tools"
                   wrapText="true" />
        </VBox>

        <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background-color: linear-gradient(to bottom, #1a1a1a, #2d2d2d); -fx-control-inner-background: linear-gradient(to bottom, #1a1a1a, #2d2d2d); -fx-padding: 0;" VBox.vgrow="ALWAYS">
            <VBox spacing="20.0" style="-fx-background-color: linear-gradient(to bottom, #1a1a1a, #2d2d2d); -fx-padding: 20 40 30 40;">

                <VBox spacing="12.0" styleClass="section-container">
                    <Label text="🎬 Converter" styleClass="section-title"/>
                    <HBox styleClass="hbox-home-page">
                        <Button mnemonicParsing="false"
                                onAction="#onOpenImageConverterPressed"
                                prefWidth="160.0"
                                styleClass="tool-button"
                                text="Image Converter"/>

                        <Button mnemonicParsing="false"
                                onAction="#onOpenVideoConverterPressed"
                                prefWidth="160.0"
                                styleClass="tool-button"
                                text="Video Converter"/>

                        <Button mnemonicParsing="false"
                                onAction="#onOpenMP3ConverterPressed"
                                prefWidth="160.0"
                                styleClass="tool-button"
                                text="Audio Converter"/>
                    </HBox>
                </VBox>

                <VBox spacing="12.0" styleClass="section-container">
                    <Label text="🗜  Compressors" styleClass="section-title"/>
                    <HBox styleClass="hbox-home-page">
                        <Button mnemonicParsing="false"
                                onAction="#onOpenImageCompressorPressed"
                                prefWidth="160.0"
                                styleClass="tool-button"
                                text="Compress Image"/>

                        <Button mnemonicParsing="false"
                                onAction="#onOpenVideoCompressorPressed"
                                prefWidth="160.0"
                                styleClass="tool-button"
                                text="Compress Video"/>

                        <Button mnemonicParsing="false"
                                onAction="#onOpenCompressorPdfPressed"
                                prefWidth="160.0"
                                styleClass="tool-button"
                                text="Compress PDF"/>
                    </HBox>
                </VBox>

                <VBox spacing="12.0" styleClass="section-container">
                    <Label text="🖼 Image Tools" styleClass="section-title"/>
                    <HBox styleClass="hbox-home-page">
                        <Button mnemonicParsing="false"
                                onAction="#onOpenNegativeImagePressed"
                                prefWidth="160.0"
                                styleClass="tool-button"
                                text="Negative"/>

                        <Button mnemonicParsing="false"
                                onAction="#onOpenTurnImagePressed"
                                prefWidth="160.0"
                                styleClass="tool-button"
                                text="Rotate"/>

                        <Button mnemonicParsing="false"
                                onAction="#onOpenLightenImagePressed"
                                prefWidth="160.0"
                                styleClass="tool-button"
                                text="Lighten"/>

                        <Button mnemonicParsing="false"
                                onAction="#onOpenDarkenImagePressed"
                                prefWidth="160.0"
                                styleClass="tool-button"
                                text="Darken"/>
                    </HBox>

                    <HBox styleClass="hbox-home-page">
                        <Button mnemonicParsing="false"
                                onAction="#onOpenColorizeImagePressed"
                                prefWidth="160.0"
                                styleClass="tool-button"
                                text="Colorize"/>

                        <Button mnemonicParsing="false"
                                onAction="#onOpenBlackAndWhiteImagePressed"
                                prefWidth="160.0"
                                styleClass="tool-button"
                                text="B&amp;W"/>

                        <Button mnemonicParsing="false"
                                onAction="#onOpenBlurImagePressed"
                                prefWidth="160.0"
                                styleClass="tool-button"
                                text="Blur"/>

                        <Button mnemonicParsing="false"
                                onAction="#onOpenFindPixelPressed"
                                prefWidth="160.0"
                                styleClass="tool-button"
                                text="Find Pixel"/>
                    </HBox>

                    <HBox styleClass="hbox-home-page">
                        <Button mnemonicParsing="false"
                                onAction="#onOpenCropImagePressed"
                                prefWidth="160.0"
                                styleClass="tool-button"
                                text="Crop"/>

                        <Button mnemonicParsing="false"
                                onAction="#onOpenColorReplaceInImagePressed"
                                prefWidth="160.0"
                                styleClass="tool-button"
                                text="Color Replace"/>
                    </HBox>
                </VBox>

                <VBox spacing="12.0" styleClass="section-container">
                    <Label text="📄 PDF Tools" styleClass="section-title"/>
                    <HBox styleClass="hbox-home-page">
                        <Button mnemonicParsing="false"
                                onAction="#onOpenImageToPdfPressed"
                                prefWidth="160.0"
                                styleClass="tool-button"
                                text="Image to PDF"/>

                        <Button mnemonicParsing="false"
                                onAction="#onOpenPdfToImagePressed"
                                prefWidth="160.0"
                                styleClass="tool-button"
                                text="PDF to Image"/>

                        <Button mnemonicParsing="false"
                                onAction="#onOpenImagesToPdfPressed"
                                prefWidth="160.0"
                                styleClass="tool-button"
                                text="Merge Images"/>

                        <Button mnemonicParsing="false"
                                onAction="#onOpenProtectPdfPressed"
                                prefWidth="160.0"
                                styleClass="tool-button"
                                text="Protect PDF"/>
                    </HBox>

                    <HBox styleClass="hbox-home-page">
                        <Button mnemonicParsing="false"
                                onAction="#onOpenUnlockPdfPressed"
                                prefWidth="160.0"
                                styleClass="tool-button"
                                text="Unlock PDF"/>

                        <Button mnemonicParsing="false"
                                onAction="#onOpenRemovePagesPdfPressed"
                                prefWidth="160.0"
                                styleClass="tool-button"
                                text="Remove Pages"/>

                        <Button mnemonicParsing="false"
                                onAction="#onOpenMergePdfPressed"
                                prefWidth="160.0"
                                styleClass="tool-button"
                                text="Merge PDF"/>

                        <Button mnemonicParsing="false"
                                onAction="#onOpenSplitPdfPressed"
                                prefWidth="160.0"
                                styleClass="tool-button"
                                text="Split PDF"/>
                    </HBox>
                </VBox>

                <VBox spacing="12.0" styleClass="section-container">
                    <Label text="🎵 Audio Tools" styleClass="section-title"/>
                    <HBox styleClass="hbox-home-page">
                        <Button mnemonicParsing="false"
                                onAction="#onOpenEditorAudioTagPressed"
                                prefWidth="160.0"
                                styleClass="tool-button"
                                text="Tag Editor"/>
                    </HBox>
                </VBox>

                <HBox alignment="CENTER">
                    <Button mnemonicParsing="false"
                            onAction="#onOpenInfoPressed"
                            styleClass="info-tool-button"
                            text="Application Info"/>
                </HBox>

            </VBox>
        </ScrollPane>

    </VBox>

    <Button text="?"
            onAction="#showInfo"
            styleClass="info-button"
            StackPane.alignment="TOP_LEFT">
        <StackPane.margin>
            <Insets top="10.0" left="10.0"/>
        </StackPane.margin>
    </Button>
</StackPane>
