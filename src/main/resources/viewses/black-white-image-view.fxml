<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/25"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="media_multitool.BlackWhiteImageController">
    <VBox alignment="TOP_CENTER"
          prefHeight="820.0"
          prefWidth="630.0"
          spacing="12.0"
          style="-fx-background-color: #4b4b4b;">

        <Label alignment="CENTER"
               prefWidth="320.0"
               text="Black and White Image"
               textFill="RED"
               style="-fx-font-size: 22px; -fx-font-weight: bold;">
            <VBox.margin>
                <Insets top="8.0"/>
            </VBox.margin>
        </Label>

        <HBox alignment="CENTER" spacing="20.0">
            <Button fx:id="btnSelectPhotoFile"
                    mnemonicParsing="false"
                    onAction="#onActionBtnSelectFile"
                    prefWidth="180.0"
                    text="Select image file"/>

            <Button fx:id="btnChoiceDirForSaveImage"
                    mnemonicParsing="false"
                    onAction="#btnChoiceDirForSaveImage"
                    prefWidth="180.0"
                    text="Directory for save">
                <tooltip>
                    <Tooltip text="Default directory: Desktop" />
                </tooltip>
            </Button>
        </HBox>

        <VBox alignment="CENTER" spacing="8.0">
            <Label fx:id="labelSuccess" styleClass="labelSuccess"
                   alignment="CENTER"
                   prefWidth="560.0"
                   minHeight="20.0"
                   prefHeight="20.0"
                   visible="false"
                   text="Black-White status: success"
                   textFill="#32CD32"
                   wrapText="true"/>

            <Button mnemonicParsing="false"
                    onAction="#submitAndDownload"
                    prefWidth="240.0"
                    text="Download" />
        </VBox>

        <GridPane hgap="12.0" VBox.vgrow="ALWAYS">
            <padding>
                <Insets left="4.0" right="4.0"/>
            </padding>
            <VBox.margin>
                <Insets top="2.0"/>
            </VBox.margin>
            <columnConstraints>
                <ColumnConstraints percentWidth="50.0" hgrow="ALWAYS"/>
                <ColumnConstraints percentWidth="50.0" hgrow="ALWAYS"/>
            </columnConstraints>
            <rowConstraints>
                <RowConstraints vgrow="ALWAYS"/>
            </rowConstraints>
            <StackPane fx:id="previewContainer"
                       GridPane.columnIndex="0"
                       minHeight="200.0"
                       prefHeight="300.0"
                       style="-fx-border-color: white; -fx-border-style: solid; -fx-border-width: 2; -fx-border-radius: 10;">
                <ImageView fx:id="imageViewPreview"
                           preserveRatio="true"/>
                <Label fx:id="labelPreviewPlaceholder" text="Preview" textFill="WHITE" style="-fx-font-size: 16px;"/>
            </StackPane>

            <StackPane fx:id="dropZone" styleClass="drop-zone"
                       onDragOver="#handleDragOver"
                       onDragDropped="#handleDragDropped"
                       GridPane.columnIndex="1"
                       minHeight="200.0"
                       prefHeight="300.0"
                       style="-fx-border-color: white; -fx-border-style: dashed; -fx-border-width: 2; -fx-border-radius: 10;">
                <Label fx:id="textDragZone" text="Drag files here" textFill="WHITE" style="-fx-font-size: 18px;"/>
            </StackPane>
        </GridPane>

        <VBox alignment="CENTER" spacing="4.0">
            <Label fx:id="labelSelectImageName" styleClass="labelSelect"
                   alignment="CENTER"
                   prefWidth="600.0"
                   minHeight="18.0"
                   text="Selected image file: none"
                   textFill="RED"
                   wrapText="true"/>

            <Button fx:id="btnReset"
                    mnemonicParsing="false"
                    onAction="#onResetPressed"
                    prefWidth="240.0"
                    text="Reset"/>
        </VBox>

        <padding>
            <Insets top="8.0" left="16.0" right="16.0" bottom="16.0"/>
        </padding>
    </VBox>

    <Button text="?"
            onAction="#showInfo"
            styleClass="info-button"
            StackPane.alignment="TOP_LEFT">
        <StackPane.margin>
            <Insets top="10.0" left="10.0"/>
        </StackPane.margin>
    </Button>
</StackPane>
