<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17.0.12"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="media_multitool.converters.ConverterAudioController">
    <VBox alignment="TOP_CENTER"
          prefHeight="820.0"
          prefWidth="630.0"
          spacing="12.0"
          style="-fx-background-color: #4b4b4b;">


        <Label styleClass="main-label-name-page"
               text="Audio Converter">
            <VBox.margin>
                <Insets top="8.0"/>
            </VBox.margin>
        </Label>

        <HBox alignment="CENTER" spacing="20.0">
            <Button fx:id="btnSelectAudioVideoFile" mnemonicParsing="false" onAction="#onSelectAudioVideoPressed" prefWidth="180.0" text="Select audio/video file" />

            <Button fx:id="btnChoiceDirForSave" mnemonicParsing="false" onAction="#onSelectOutputDirectoryPressed" prefWidth="180.0" text="Directory for save" >
                <tooltip>
                    <Tooltip text="Default directory: Desktop" />
                </tooltip>
            </Button>
        </HBox>


        <HBox alignment="CENTER" spacing="16.0">
            <ToggleButton fx:id="btnToMP3" mnemonicParsing="false"
                          onAction="#onActionClickToggleBtnFormat"
                          prefWidth="100.0"
                          text="to MP3"/>

            <ToggleButton fx:id="btnToAAC" mnemonicParsing="false"
                          onAction="#onActionClickToggleBtnFormat"
                          prefWidth="100.0"
                          text="to AAC"/>

            <ToggleButton fx:id="btnToOggVorbis" mnemonicParsing="false"
                          onAction="#onActionClickToggleBtnFormat"
                          prefWidth="100.0"
                          text="to OGG"/>

            <ToggleButton fx:id="btnToOPUS" mnemonicParsing="false"
                          onAction="#onActionClickToggleBtnFormat"
                          prefWidth="100.0"
                          text="to OPUS"/>
        </HBox>

        <HBox alignment="CENTER" spacing="16.0">
            <ToggleButton fx:id="btnToFLAC" mnemonicParsing="false"
                          onAction="#onActionClickToggleBtnFormat"
                          prefWidth="100.0"
                          text="to FLAC"/>

            <ToggleButton fx:id="btnToALAC" mnemonicParsing="false"
                          onAction="#onActionClickToggleBtnFormat"
                          prefWidth="100.0"
                          text="to ALAC"/>

            <ToggleButton fx:id="btnToWAV" mnemonicParsing="false"
                          onAction="#onActionClickToggleBtnFormat"
                          prefWidth="100.0"
                          text="to WAV"/>

            <ToggleButton fx:id="btnToAIFF" mnemonicParsing="false"
                          onAction="#onActionClickToggleBtnFormat"
                          prefWidth="100.0"
                          text="to AIFF"/>
        </HBox>

        <HBox alignment="CENTER" spacing="16.0">
            <ComboBox fx:id="comboBoxChoiceBitRate" onAction="#onChoiceComboBox" prefWidth="140.0" styleClass="comboBoxMP3"/>
            <ComboBox fx:id="comboBoxChoiceChannels" onAction="#onChoiceComboBox" prefWidth="140.0" styleClass="comboBoxMP3"/>
            <ComboBox fx:id="comboBoxChoiceSamplingRate" onAction="#onChoiceComboBox" prefWidth="140.0" styleClass="comboBoxMP3" />
        </HBox>

        <StackPane>
            <VBox.margin>
                <Insets top="4.0"/>
            </VBox.margin>
            <HBox alignment="CENTER" spacing="10.0">
                <Button fx:id="btnSubmitAndDownload"
                        mnemonicParsing="false"
                        onAction="#onStartConversionPressed"
                        prefWidth="220.0" text="Convert and Download" >
                    <tooltip>
                        <Tooltip text="Converting a large file may take longer!" />
                    </tooltip>
                </Button>

                <Button fx:id="btnCancelConversion"
                        mnemonicParsing="false"
                        onAction="#onCancelConversion"
                        prefWidth="220.0" text="Cancel Conversion" />
            </HBox>
        </StackPane>

        <VBox alignment="CENTER" spacing="8.0">
            <VBox.margin>
                <Insets top="2.0" />
            </VBox.margin>
            <ProgressBar fx:id="progressBar"
                         prefWidth="460.0"
                         minHeight="16.0"
                         progress="0.0"/>

            <StackPane minHeight="24.0" prefHeight="24.0">
                <Label fx:id="labelSuccess"
                       styleClass="labelSuccess"
                       textFill="#32CD32"
                       text="Convert has been success!" />
            </StackPane>
        </VBox>


        <HBox spacing="5.0" VBox.vgrow="ALWAYS">
            <padding>
                <Insets left="4.0" right="4.0" />
            </padding>
            <VBox.margin>
                <Insets top="2.0" />
            </VBox.margin>
            <StackPane fx:id="dropZone" styleClass="drop-zone-solo" HBox.hgrow="ALWAYS"
                       maxWidth="Infinity"
                       maxHeight="Infinity"
                       minHeight="200.0">
                <Label fx:id="textDragZone" styleClass="label-drag-zone" text="Drag files here"  />
            </StackPane>
        </HBox>

        <VBox alignment="CENTER" spacing="6.0">
            <Label fx:id="labelSelectFile" styleClass="labelSelect"
                   text="Selected file: none" />

            <Button fx:id="btnReset" styleClass="btn-reset"
                    mnemonicParsing="false"
                    onAction="#isPressedReset"
                    text="Reset"/>
        </VBox>

        <padding>
            <Insets top="8.0" bottom="16.0" left="16.0" right="16.0" />
        </padding>
    </VBox>

    <Button text="?"
            onAction="#showInfo"
            styleClass="info-button"
            StackPane.alignment="TOP_LEFT">
        <StackPane.margin>
            <Insets top="10.0" left="10.0"/>
        </StackPane.margin>
    </Button>
</StackPane>
