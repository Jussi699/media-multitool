<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.image.ImageView?>

<StackPane xmlns="http://javafx.com/javafx/17.0.12"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="media_multitool.converters.ConverterImageController">
    <VBox alignment="TOP_CENTER"
          maxWidth="Infinity"
          maxHeight="Infinity"
          spacing="14.0"
          style="-fx-background-color: #4b4b4b;">

        <Label text="Convert Image"
               styleClass="main-label-name-page">
            <VBox.margin>
                <Insets top="8.0"/>
            </VBox.margin>
        </Label>


        <HBox alignment="CENTER" spacing="20.0">
            <Button fx:id="btnSelectFile"
                    mnemonicParsing="false"
                    onAction="#onActionBtnSelectFile"
                    prefWidth="180.0"
                    text="Select image"/>

            <Button fx:id="btnSelectBatchFileProcessing"
                    mnemonicParsing="false"
                    onAction="#onActionBtnBatchFileProcessing"
                    prefWidth="180.0"
                    text="Batch file processing"/>

            <Button fx:id="btnChoiceFolderForSaveFile"
                    mnemonicParsing="false"
                    onAction="#onChoiceFolderForSaveFile"
                    prefWidth="180.0"
                    text="Directory for save">
                <tooltip>
                    <Tooltip text="Default directory: Desktop" />
                </tooltip>
            </Button>
        </HBox>

            <HBox alignment="CENTER" spacing="20.0">
                <ToggleButton fx:id="btnToPNG"
                              mnemonicParsing="false"
                              onAction="#onActionClickToggleBtnFormat"
                              prefWidth="85.0"
                              text="to PNG"/>

                <ToggleButton fx:id="btnToJPEG"
                              mnemonicParsing="false"
                              onAction="#onActionClickToggleBtnFormat"
                              prefWidth="85.0"
                              text="to JPEG"/>

                <ToggleButton fx:id="btnToWEBP"
                              mnemonicParsing="false"
                              onAction="#onActionClickToggleBtnFormat"
                              prefWidth="85.0"
                              text="to WEBP"/>


                <ComboBox fx:id="comboBoxIcoSize"
                          onAction="#onActionChoiceIcoSize"
                          prefWidth="100.0"/>
            </HBox>

            <HBox alignment="CENTER" spacing="16.0">
                <ToggleButton fx:id="btnToTIFF"
                              mnemonicParsing="false"
                              onAction="#onActionClickToggleBtnFormat"
                              prefWidth="85.0"
                              text="to TIFF"/>

                <ToggleButton fx:id="btnToBMP"
                              mnemonicParsing="false"
                              onAction="#onActionClickToggleBtnFormat"
                              prefWidth="85.0"
                              text="to BMP"/>

                <ToggleButton fx:id="btnToPPM"
                              mnemonicParsing="false"
                              onAction="#onActionClickToggleBtnFormat"
                              prefWidth="85.0"
                              text="to PPM"/>

                <ToggleButton fx:id="btnToPGM"
                              mnemonicParsing="false"
                              onAction="#onActionClickToggleBtnFormat"
                              prefWidth="85.0"
                              text="to PGM"/>

                <ToggleButton fx:id="btnToPAM"
                              mnemonicParsing="false"
                              onAction="#onActionClickToggleBtnFormat"
                              prefWidth="85.0"
                              text="to PAM"/>

                <ToggleButton fx:id="btnToSVG"
                              mnemonicParsing="false"
                              onAction="#onActionClickToggleBtnFormat"
                              prefWidth="85.0"
                              text="to SVG"/>
            </HBox>

        <VBox alignment="CENTER" spacing="8.0">
            <Label fx:id="labelSuccess"
                   styleClass="labelSuccess"
                   visible="false"
                   text="Conversion status"/>

            <VBox alignment="CENTER" spacing="10.0">
                <Button fx:id="btnSubmit" mnemonicParsing="false"
                        onAction="#submitAndDownload"
                        prefWidth="240.0"
                        text="Convert and Download"/>
            </VBox>
        </VBox>

        <VBox spacing="10.0" VBox.vgrow="ALWAYS" >
            <padding>
                <Insets left="4.0" right="4.0" />
            </padding>
            <VBox.margin>
                <Insets top="2.0" />
            </VBox.margin>
            <StackPane fx:id="previewContainer" styleClass="preview-container" VBox.vgrow="ALWAYS" minWidth="200">
                <ImageView fx:id="imageViewPreview" preserveRatio="true" />
                <Label fx:id="labelPreviewPlaceholder" text="Preview"/>
            </StackPane>

            <StackPane fx:id="dropZone" styleClass="drop-zone" HBox.hgrow="ALWAYS">
                <Label fx:id="textDragZone" styleClass="label-drag-zone" text="Drag files here"  />
            </StackPane>
        </VBox>

        <VBox alignment="CENTER" spacing="6.0">
            <Label fx:id="labelSelectFile" styleClass="labelSelect"
                   text="Selected image file: none" />

            <Button fx:id="btnReset" styleClass="btn-reset"
                    mnemonicParsing="false"
                    onAction="#isPressedReset"
                    text="Reset"/>
        </VBox>

        <padding>
            <Insets top="8.0" left="16.0" right="16.0" bottom="16.0"/>
        </padding>
    </VBox>

    <Button text="?"
            onAction="#showInfo"
            styleClass="info-button"
            StackPane.alignment="TOP_LEFT">
        <StackPane.margin>
            <Insets top="10.0" left="10.0"/>
        </StackPane.margin>
    </Button>
</StackPane>
