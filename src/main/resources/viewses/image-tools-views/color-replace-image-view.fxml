<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/25"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="media_multitool.imageTools.ColorReplaceImageController">
    <VBox alignment="TOP_CENTER"
          prefHeight="820.0"
          prefWidth="630.0"
          spacing="12.0"
          style="-fx-background-color: #4b4b4b;">

        <Label styleClass="main-label-name-page"
               text="Color Replace">
            <VBox.margin>
                <Insets top="8.0"/>
            </VBox.margin>
        </Label>

        <HBox alignment="CENTER" spacing="20.0">
            <Button fx:id="btnSelectFile"
                    mnemonicParsing="false"
                    onAction="#onActionBtnSelectFile"
                    prefWidth="180.0"
                    text="Select image file"/>

            <Button fx:id="btnChoiceFolderForSaveFile"
                    mnemonicParsing="false"
                    onAction="#onChoiceFolderForSaveFile"
                    prefWidth="180.0"
                    text="Directory for save">
                <tooltip>
                    <Tooltip text="Default directory: Desktop" />
                </tooltip>
            </Button>
        </HBox>

        <VBox spacing="8.0" alignment="CENTER">
            <Label text="Source Color (Color to Replace)" styleClass="label-h"/>
            <HBox alignment="CENTER" spacing="10.0">
                <Label text="Color:" minWidth="50" styleClass="label-parameter"/>
                <ComboBox fx:id="comboSourceColor" prefWidth="120.0"/>
                <Label text="HEX:" minWidth="40" styleClass="label-parameter"/>
                <TextField fx:id="textSourceColorHex" prefWidth="100.0" promptText="#FF0000"/>
            </HBox>
        </VBox>

        <VBox spacing="8.0" alignment="CENTER">
            <CheckBox fx:id="checkBoxReplaceAllColors" text="Replace All Colors (Shift entire image to target color)" styleClass="checkbox-replace-mode"/>
        </VBox>

        <VBox spacing="8.0" alignment="CENTER">
            <Label text="Target Color (New Color)" styleClass="label-h"/>
            <HBox alignment="CENTER" spacing="10.0">
                <Label text="Color:" minWidth="50" styleClass="label-parameter"/>
                <ComboBox fx:id="comboTargetColor" prefWidth="120.0"/>
                <Label text="HEX:" minWidth="40" styleClass="label-parameter"/>
                <TextField fx:id="textTargetColorHex" prefWidth="100.0" promptText="#0000FF"/>
            </HBox>
        </VBox>

        <HBox spacing="15.0" alignment="CENTER">
            <VBox alignment="CENTER" spacing="10.0">
                <Label text="Intensity (1.0-100.0):" minWidth="150" styleClass="label-parameter"/>
                <Spinner fx:id="spinnerIntensity" prefWidth="150.0" editable="true"/>
            </VBox>
            
            <VBox alignment="CENTER" spacing="10.0">
                <Label text="Smoothing (0-50):" minWidth="150" styleClass="label-parameter"/>
                <Spinner fx:id="spinnerSmoothing" prefWidth="150.0" editable="true"/>
            </VBox>
            
            <VBox alignment="CENTER" spacing="10.0">
                <Label text="Enhancement (1-100):" minWidth="150" styleClass="label-parameter"/>
                <Spinner fx:id="spinnerEnhancement" prefWidth="150.0" editable="true"/>
            </VBox>
        </HBox>

        <VBox spacing="8.0" alignment="CENTER">
            <Label text="Output Format" styleClass="label-h"/>
            <HBox alignment="CENTER" spacing="15.0">
                <ToggleButton fx:id="toggleJPEG" text="JPEG" prefWidth="80.0"/>
                <ToggleButton fx:id="togglePNG" text="PNG" prefWidth="80.0"/>
            </HBox>
        </VBox>

        <VBox alignment="CENTER" spacing="8.0">
            <Label fx:id="labelSuccess" styleClass="labelSuccess"
                   visible="false"
                   text="Status: success"/>

            <Button fx:id="btnSubmit" mnemonicParsing="false"
                    onAction="#submitReplaceColorAndDownload"
                    prefWidth="240.0"
                    text="Replace Color and Download" />
        </VBox>

        <VBox spacing="10.0" VBox.vgrow="ALWAYS" >
            <padding>
                <Insets left="4.0" right="4.0" />
            </padding>
            <VBox.margin>
                <Insets top="2.0" />
            </VBox.margin>
            <StackPane fx:id="previewContainer" styleClass="preview-container" VBox.vgrow="ALWAYS" minWidth="200">
                <ImageView fx:id="imageViewPreview" preserveRatio="true" />
                <Label fx:id="labelPreviewPlaceholder" text="Preview"/>
            </StackPane>

            <StackPane fx:id="dropZone" styleClass="drop-zone" HBox.hgrow="ALWAYS">
                <Label fx:id="textDragZone" styleClass="label-drag-zone" text="Drag files here"  />
            </StackPane>
        </VBox>

        <VBox alignment="CENTER" spacing="4.0">
            <Label fx:id="labelSelectImageName" styleClass="labelSelect"
                   text="Selected image file: none"/>

            <Button fx:id="btnReset"
                    mnemonicParsing="false"
                    onAction="#isPressedReset"
                    prefWidth="240.0"
                    text="Reset"/>
        </VBox>

        <padding>
            <Insets top="8.0" left="16.0" right="16.0" bottom="16.0"/>
        </padding>
    </VBox>

    <Button text="?"
            onAction="#showInfo"
            styleClass="info-button"
            StackPane.alignment="TOP_LEFT">
        <StackPane.margin>
            <Insets top="10.0" left="10.0"/>
        </StackPane.margin>
    </Button>
</StackPane>
