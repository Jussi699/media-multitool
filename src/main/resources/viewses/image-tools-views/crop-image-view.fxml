<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Rectangle?>

<StackPane xmlns="http://javafx.com/javafx/25"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="media_multitool.imageTools.CropImageController">
    <VBox alignment="TOP_CENTER"
          prefHeight="820.0"
          prefWidth="630.0"
          spacing="12.0"
          style="-fx-background-color: #4b4b4b;">

        <Label styleClass="main-label-name-page"
               text="Crop Image">
            <VBox.margin>
                <Insets top="8.0" />
            </VBox.margin>
        </Label>

        <HBox alignment="CENTER" spacing="20.0">
            <Button fx:id="btnSelectFile"
                    mnemonicParsing="false"
                    onAction="#onActionBtnSelectFile"
                    prefWidth="180.0"
                    text="Select image file" />

            <Button fx:id="btnChoiceFolderForSaveFile"
                    mnemonicParsing="false"
                    onAction="#onChoiceFolderForSaveFile"
                    prefWidth="180.0"
                    text="Directory for save">
                <tooltip>
                    <Tooltip text="Default directory: Desktop" />
                </tooltip>
            </Button>
        </HBox>

        <VBox alignment="CENTER" spacing="8.0">
            <Label fx:id="labelSuccess"
                   styleClass="labelSuccess"
                   text="Crop image status: success"
                   visible="false" />

            <Button fx:id="btnSubmit" mnemonicParsing="false"
                    onAction="#submitAndDownload"
                    prefWidth="240.0"
                    text="Crop and Download" />
        </VBox>

        <VBox spacing="12.0" VBox.vgrow="ALWAYS">
            <padding>
                <Insets left="4.0" right="4.0" />
            </padding>
            <VBox.margin>
                <Insets top="2.0" />
            </VBox.margin>

            <ScrollPane fx:id="scrollPaneImage" fitToHeight="true" fitToWidth="true" pannable="true" styleClass="scroll-pane-image" VBox.vgrow="ALWAYS">
                <StackPane fx:id="previewContainer" minHeight="200.0">
                    <ImageView fx:id="imageViewPreview" preserveRatio="true" />
                    <Pane fx:id="cropOverlay">
                        <Rectangle fx:id="cropRect"
                                   visible="false"
                        />
                    </Pane>
                    <Label fx:id="labelPreviewPlaceholder" style="-fx-font-size: 16px;" text="Preview" textFill="WHITE" />
                </StackPane>
            </ScrollPane>

            <HBox spacing="12.0">
                <StackPane maxHeight="120.0"  minHeight="120.0" prefHeight="120.0"
                           style="-fx-border-color: white; -fx-border-style: dashed; -fx-border-width: 2; -fx-border-radius: 10;" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER" spacing="12.0">
                        <padding>
                            <Insets bottom="5.0" left="10.0" right="10.0" top="5.0" />
                        </padding>

                        <VBox alignment="CENTER" spacing="8.0">
                            <HBox alignment="CENTER" spacing="12.0">
                                <Button fx:id="btnAspectRatioSquare"
                                        mnemonicParsing="false"
                                        onAction="#onActionSelectAspectRatio"
                                        styleClass="btn-aspect-ratio"
                                        text="Square" />

                                <Button fx:id="btnAspectRatio9x16"
                                        mnemonicParsing="false"
                                        onAction="#onActionSelectAspectRatio"
                                        styleClass="btn-aspect-ratio"
                                        text="9 : 16" />

                                <Button fx:id="btnAspectRatio16x9"
                                        mnemonicParsing="false"
                                        onAction="#onActionSelectAspectRatio"
                                        styleClass="btn-aspect-ratio"
                                        text="16 : 9" />

                                <Button fx:id="btnAspectRatio4x5"
                                        mnemonicParsing="false"
                                        onAction="#onActionSelectAspectRatio"
                                        styleClass="btn-aspect-ratio"
                                        text="4 : 5" />

                                <Button fx:id="btnAspectRatio5x4"
                                        mnemonicParsing="false"
                                        onAction="#onActionSelectAspectRatio"
                                        styleClass="btn-aspect-ratio"
                                        text="5 : 4" />

                                <Button fx:id="btnAspectRatio3x4"
                                        mnemonicParsing="false"
                                        onAction="#onActionSelectAspectRatio"
                                        styleClass="btn-aspect-ratio"
                                        text="3 : 4" />
                            </HBox>
                            <HBox alignment="CENTER" spacing="12.0">
                                <Button fx:id="btnAspectRatio4x3"
                                        mnemonicParsing="false"
                                        onAction="#onActionSelectAspectRatio"
                                        styleClass="btn-aspect-ratio"
                                        text="4 : 3" />

                                <Button fx:id="btnAspectRatio2x3"
                                        mnemonicParsing="false"
                                        onAction="#onActionSelectAspectRatio"
                                        styleClass="btn-aspect-ratio"
                                        text="2 : 3" />

                                <Button fx:id="btnAspectRatio3x2"
                                        mnemonicParsing="false"
                                        onAction="#onActionSelectAspectRatio"
                                        styleClass="btn-aspect-ratio"
                                        text="3 : 2" />

                                <Button fx:id="btnAspectRatio5x7"
                                        mnemonicParsing="false"
                                        onAction="#onActionSelectAspectRatio"
                                        styleClass="btn-aspect-ratio"
                                        text="5 : 7" />

                                <Button fx:id="btnAspectRatio7x5"
                                        mnemonicParsing="false"
                                        onAction="#onActionSelectAspectRatio"
                                        styleClass="btn-aspect-ratio"
                                        text="5 : 7" />

                                <Button fx:id="btnAspectRatio1x2"
                                        mnemonicParsing="false"
                                        onAction="#onActionSelectAspectRatio"
                                        styleClass="btn-aspect-ratio"
                                        text="1 : 2" />

                                <Button fx:id="btnAspectRatio2x1"
                                        mnemonicParsing="false"
                                        onAction="#onActionSelectAspectRatio"
                                        styleClass="btn-aspect-ratio"
                                        text="2 : 1" />
                            </HBox>
                        </VBox>
                    </HBox>
                </StackPane>
                <StackPane fx:id="dropZone" maxHeight="120.0" minHeight="120.0" prefHeight="120.0" HBox.hgrow="ALWAYS" styleClass="drop-zone-crop">

                    <Label fx:id="textDragZone" styleClass="label-drag-zone" text="Drag files here" textFill="WHITE" />
                </StackPane>
            </HBox>
        </VBox>

        <VBox alignment="CENTER" spacing="4.0">
            <HBox alignment="CENTER" spacing="10.0">
                <Label text="-" textFill="RED" />
                <Slider fx:id="imageScaleSlider"
                        max="3.0"
                        min="1.0"
                        prefWidth="300.0"
                        value="1.0" />
                <Label text="+" textFill="RED" />
            </HBox>

            <Label fx:id="labelSelectImageName"
                   styleClass="labelSelect"
                   text="Selected image file: none" />

            <Button fx:id="btnReset"
                    mnemonicParsing="false"
                    onAction="#isPressedReset"
                    prefWidth="240.0"
                    text="Reset" />
        </VBox>

        <padding>
            <Insets bottom="16.0" left="16.0" right="16.0" top="8.0" />
        </padding>
    </VBox>

    <Button onAction="#showInfo"
            styleClass="info-button"
            text="?"
            StackPane.alignment="TOP_LEFT">
        <StackPane.margin>
            <Insets left="10.0" top="10.0" />
        </StackPane.margin>
    </Button>
</StackPane>
