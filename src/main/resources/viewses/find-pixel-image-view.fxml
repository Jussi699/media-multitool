<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<?import javafx.scene.text.TextFlow?>
<StackPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="media_multitool.FindPixelImageController">
    <VBox alignment="TOP_CENTER" prefHeight="820.0" prefWidth="630.0" spacing="12.0" style="-fx-background-color: #4b4b4b;">

        <Label text="Find Pixel"
               styleClass="main-label-name-page">
            <VBox.margin>
                <Insets top="8.0"/>
            </VBox.margin>
        </Label>

        <HBox alignment="CENTER" spacing="20.0">
            <Button fx:id="btnSelectFile" mnemonicParsing="false" onAction="#onActionBtnSelectFile" prefWidth="180.0" text="Select image file" />
        </HBox>

        <VBox spacing="12.0" VBox.vgrow="ALWAYS">
            <padding>
                <Insets left="4.0" right="4.0" />
            </padding>
            <VBox.margin>
                <Insets top="2.0" />
            </VBox.margin>

            <ScrollPane fx:id="scrollPanePhoto" fitToHeight="true" fitToWidth="true" pannable="true" styleClass="scroll-pane-image" VBox.vgrow="ALWAYS">
                <StackPane fx:id="previewContainer" minHeight="200.0">
                    <ImageView fx:id="imageViewPreview" preserveRatio="true" />
                    <Label fx:id="labelPreviewPlaceholder" style="-fx-font-size: 16px;" text="Preview" textFill="WHITE" />
                </StackPane>
            </ScrollPane>

            <HBox spacing="12.0">
                <StackPane maxHeight="150.0"  minHeight="150.0" prefHeight="150.0"
                           style="-fx-border-color: white; -fx-border-style: dashed; -fx-border-width: 2; -fx-border-radius: 10;" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER" spacing="12.0">
                        <padding>
                            <Insets bottom="5.0" left="10.0" right="10.0" top="5.0" />
                        </padding>

                        <VBox alignment="CENTER" spacing="8.0">
                            <HBox alignment="CENTER" spacing="12.0">
                                <VBox spacing="1.0">
                                    <Label styleClass="label-find-pixel" text="R:" textFill="RED" />
                                    <HBox alignment="CENTER_LEFT" spacing="4.0">
                                        <TextField fx:id="textFieldR" promptText="0" styleClass="text-field-find-pixel" />
                                    </HBox>
                                </VBox>
                                <VBox spacing="1.0">
                                    <Label styleClass="label-find-pixel" text="G:" textFill="GREEN" />
                                    <HBox alignment="CENTER_LEFT" spacing="4.0">
                                        <TextField fx:id="textFieldG" promptText="0" styleClass="text-field-find-pixel" />
                                    </HBox>
                                </VBox>
                                <VBox spacing="1.0">
                                    <Label styleClass="label-find-pixel" text="B:" textFill="BLUE" />
                                    <HBox alignment="CENTER_LEFT" spacing="4.0">
                                        <TextField fx:id="textFieldB" promptText="0" styleClass="text-field-find-pixel" />
                                    </HBox>
                                </VBox>
                            </HBox>
                            <HBox alignment="CENTER" spacing="12.0">
                                <VBox spacing="1.0">
                                    <TextFlow>
                                        <Label styleClass="label-find-pixel" text="R" textFill="RED" />
                                        <Label styleClass="label-find-pixel" text="G" textFill="GREEN" />
                                        <Label styleClass="label-find-pixel" text="B:" textFill="BLUE" />
                                    </TextFlow>
                                    <HBox alignment="CENTER_LEFT" spacing="4.0">
                                        <TextField fx:id="textFieldRGB" promptText="RGB" styleClass="text-field-find-pixel" />
                                        <Button minWidth="28.0" onMouseClicked="#onClickSaveRGB" styleClass="btn-find-pixel" text="💾" />
                                    </HBox>
                                </VBox>
                                <VBox spacing="1.0">
                                    <Label fx:id="labelHex" styleClass="label-find-pixel" text="HEX:" textFill="WHITE" />
                                    <HBox alignment="CENTER_LEFT" spacing="4.0">
                                        <TextField fx:id="textFieldHEX" promptText="#000000" styleClass="text-field-find-pixel" />
                                        <Button minWidth="28.0" onMouseClicked="#onClickSaveHex" styleClass="btn-find-pixel" text="💾" />
                                    </HBox>
                                </VBox>
                            </HBox>
                        </VBox>

                        <StackPane>
                            <Rectangle fx:id="colorPreview"
                                       arcHeight="10.0"
                                       arcWidth="10.0"
                                       fill="WHITE"
                                       height="85.0"
                                       stroke="WHITE"
                                       strokeType="INSIDE"
                                       strokeWidth="2.0"
                                       width="85.0" />
                        </StackPane>
                    </HBox>
                </StackPane>
                <StackPane fx:id="dropZone" maxHeight="150.0" minHeight="150.0" prefHeight="150.0" HBox.hgrow="ALWAYS" styleClass="drop-zone-find-pixel">

                    <Label fx:id="textDragZone" styleClass="label-drag-zone" text="Drag files here" textFill="WHITE" />
                </StackPane>
            </HBox>
        </VBox>

        <VBox alignment="CENTER" spacing="4.0">
            <HBox alignment="CENTER" spacing="10.0">
                <Label text="-" textFill="RED" />
                <Slider fx:id="imageScaleSlider" max="3.0" min="1.0" prefWidth="300.0" value="1.0" />
                <Label text="+" textFill="RED" />
            </HBox>

            <Label fx:id="labelSelectImageName"
                   styleClass="labelSelect"
                   text="Selected image file: none"/>

            <Button fx:id="btnReset" mnemonicParsing="false" onAction="#isPressedReset" prefWidth="240.0" text="Reset" />
        </VBox>

        <padding>
            <Insets bottom="16.0" left="16.0" right="16.0" top="8.0" />
        </padding>
    </VBox>

    <Button onAction="#showInfo" styleClass="info-button" text="?" StackPane.alignment="TOP_LEFT">
        <StackPane.margin>
            <Insets left="10.0" top="10.0" />
        </StackPane.margin>
    </Button>
</StackPane>
