<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/25"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="media_multitool.NegativeImageController">
    <VBox alignment="TOP_CENTER"
          prefHeight="820.0"
          prefWidth="630.0"
          spacing="12.0"
          style="-fx-background-color: #4b4b4b;">

        <Label alignment="CENTER"
               prefWidth="320.0"
               text="Negative Image"
               textFill="RED"
               style="-fx-font-size: 22px; -fx-font-weight: bold;">
            <VBox.margin>
                <Insets top="8.0"/>
            </VBox.margin>
        </Label>

        <HBox alignment="CENTER" spacing="20.0">
            <Button fx:id="btnSelectPhotoFile"
                    mnemonicParsing="false"
                    onAction="#ActionBtnSelectFile"
                    prefWidth="180.0"
                    text="Select image file"/>

            <Button fx:id="btnChoiceDirForSaveImage"
                    mnemonicParsing="false"
                    onAction="#btnChoiceDirForSaveImage"
                    prefWidth="180.0"
                    text="Directory for save"/>
        </HBox>

        <VBox alignment="CENTER" spacing="8.0">
            <Label fx:id="labelSuccess" styleClass="labelSuccess"
                   alignment="CENTER"
                   prefWidth="560.0"
                   minHeight="20.0"
                   prefHeight="20.0"
                   visible="false"
                   managed="true"
                   text="Negative status: success"
                   textFill="#32CD32"
                   wrapText="true"/>

            <Button mnemonicParsing="false"
                    onAction="#submitNegativeAndDownload"
                    prefWidth="240.0"
                    text="Negative and Download" />
        </VBox>

        <HBox alignment="CENTER" spacing="12.0" VBox.vgrow="ALWAYS">
            <padding>
                <Insets left="4.0" right="4.0" />
            </padding>
            <VBox.margin>
                <Insets top="2.0" />
            </VBox.margin>

            <StackPane fx:id="previewContainer"
                       minHeight="200.0"
                       prefHeight="300.0"
                       prefWidth="300.0"
                       HBox.hgrow="ALWAYS"
                       style="-fx-border-color: white; -fx-border-style: solid; -fx-border-width: 1; -fx-border-radius: 10;">
                <ImageView fx:id="imageViewPreview"
                           preserveRatio="true" />
                <Label fx:id="labelPreviewPlaceholder" text="Preview" textFill="WHITE" style="-fx-font-size: 16px;" />
            </StackPane>

            <StackPane fx:id="dropZone" styleClass="drop-zone"
                       onDragOver="#handleDragOver"
                       onDragDropped="#handleDragDropped"
                       minHeight="200.0"
                       prefHeight="300.0"
                       prefWidth="300.0"
                       HBox.hgrow="ALWAYS"
                       style="-fx-border-color: white; -fx-border-style: dashed; -fx-border-width: 2; -fx-border-radius: 10;">
                <Label fx:id="textDragZone" text="Drag files here" textFill="WHITE" style="-fx-font-size: 18px;" />
            </StackPane>
        </HBox>

        <VBox alignment="CENTER" spacing="4.0">
            <Label fx:id="labelSelectImageName" styleClass="labelSelect"
                   alignment="CENTER"
                   prefWidth="600.0"
                   minHeight="18.0"
                   text="Selected image file: none"
                   textFill="RED"
                   wrapText="true"/>

            <Button mnemonicParsing="false"
                    onAction="#onResetPressed"
                    prefWidth="240.0"
                    text="Reset"/>
        </VBox>

        <padding>
            <Insets top="8.0" left="16.0" right="16.0" bottom="16.0"/>
        </padding>
    </VBox>

    <Button text="?"
            onAction="#showInfo"
            styleClass="info-button"
            StackPane.alignment="TOP_LEFT">
        <StackPane.margin>
            <Insets top="10.0" left="10.0"/>
        </StackPane.margin>
    </Button>
</StackPane>
