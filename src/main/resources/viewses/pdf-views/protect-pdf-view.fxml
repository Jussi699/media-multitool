<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<StackPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="media_multitool.converters.ProtectPdfController">
    <VBox alignment="TOP_CENTER" prefHeight="820.0" prefWidth="630.0" spacing="12.0" style="-fx-background-color: #4b4b4b;">

        <Label styleClass="main-label-name-page" text="Protect PDF">
            <VBox.margin>
                <Insets top="8.0" />
            </VBox.margin>
        </Label>

        <HBox alignment="CENTER" spacing="20.0">
            <Button fx:id="btnSelectFile" mnemonicParsing="false" onAction="#onActionBtnSelectFile" prefWidth="180.0" text="Select PDF file" />

            <Button fx:id="btnChoiceDirForSaveFile" mnemonicParsing="false" onAction="#onActionChoiceDirForSaveFile" prefWidth="180.0" text="Directory for save">
                <tooltip>
                    <Tooltip text="Default directory: Desktop" />
                </tooltip>
            </Button>
        </HBox>

        <HBox alignment="CENTER" spacing="20.0">
            <VBox spacing="10.0" VBox.vgrow="ALWAYS" alignment="CENTER">
                <Label text="Set a password to protect your PDF file"  styleClass="label-h"/>
                <HBox alignment="CENTER" spacing="2.0">
                    <StackPane>
                        <PasswordField fx:id="typePasswordField" promptText="Type password" styleClass="password-field-with-button"/>
                        <TextField fx:id="typePasswordTextField" promptText="Type password" styleClass="password-field-with-button" visible="false" managed="false"/>
                    </StackPane>
                    <ToggleButton fx:id="btnShowTypePassword" text="👁" onAction="#turnShowPassword" styleClass="btn-turn-show-password"/>
                    <Label styleClass="label-password-match" visible="false"/>
                </HBox>
                <HBox alignment="CENTER" spacing="2.0">
                    <StackPane>
                        <PasswordField fx:id="repeatPasswordField" promptText="Repeat password" styleClass="password-field-with-button"/>
                        <TextField fx:id="repeatPasswordTextField" promptText="Repeat password" styleClass="password-field-with-button" visible="false" managed="false"/>
                    </StackPane>
                    <ToggleButton fx:id="btnShowRepeatPassword"  text="👁" onAction="#turnShowPassword" styleClass="btn-turn-show-password"/>
                    <Label fx:id="labelPasswordMatch" text="✓" styleClass="label-password-match" visible="false"/>
                </HBox>
            </VBox>
        </HBox>

        <VBox alignment="CENTER" spacing="8.0">
            <Label fx:id="labelSuccess" styleClass="labelSuccess" text="Conversion status" visible="false" />
            <ProgressBar fx:id="progressBar" prefWidth="240.0" progress="0.0" />
            <Button fx:id="btnSubmit" mnemonicParsing="false" onAction="#submitAndDownload" prefWidth="240.0" text="Convert and Download" />
        </VBox>

        <VBox spacing="10.0" VBox.vgrow="ALWAYS">
            <padding>
                <Insets left="4.0" right="4.0" />
            </padding>
            <VBox.margin>
                <Insets top="2.0" />
            </VBox.margin>
            <StackPane fx:id="previewContainer" minWidth="200" styleClass="preview-container" VBox.vgrow="ALWAYS">
                <Label fx:id="labelPreviewPlaceholder" text="Preview" />
                <ImageView fx:id="imageViewPdf" pickOnBounds="true" preserveRatio="true" />
            </StackPane>

            <StackPane fx:id="dropZone" styleClass="drop-zone" HBox.hgrow="ALWAYS">
                <Label fx:id="textDragZone" styleClass="label-drag-zone" text="Drag files here" />
            </StackPane>
        </VBox>

        <VBox alignment="CENTER" spacing="4.0">
            <Label fx:id="labelSelectFileName" styleClass="labelSelect" text="Selected PDF file: none" />

            <Button fx:id="btnReset" mnemonicParsing="false" onAction="#isPressedReset" prefWidth="240.0" text="Reset" />
        </VBox>

        <padding>
            <Insets bottom="16.0" left="16.0" right="16.0" top="8.0" />
        </padding>
    </VBox>

    <Button onAction="#showInfo" styleClass="info-button" text="?" StackPane.alignment="TOP_LEFT">
        <StackPane.margin>
            <Insets left="10.0" top="10.0" />
        </StackPane.margin>
    </Button>
</StackPane>
