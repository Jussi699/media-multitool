<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.Cursor?>
<StackPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="media_multitool.editors.AudioTagEditorController">
    <VBox alignment="TOP_CENTER" prefHeight="820.0" prefWidth="630.0" spacing="12.0"
          style="-fx-background-color: #4b4b4b;">

        <Label text="Audio Tag Editor"
               styleClass="main-label-name-page">
            <VBox.margin>
                <Insets top="8.0" />
            </VBox.margin>
        </Label>

        <HBox alignment="CENTER" spacing="20.0">
            <Button fx:id="btnSelectImage" mnemonicParsing="false" onAction="#onActionBtnSelectFile" prefWidth="180.0" text="Select audio file" />
            <Button fx:id="btnSelectMultipleFile" mnemonicParsing="false" onAction="#onActionBtnSelectMultipleFile" prefWidth="180.0" text="Select multiple file" />

            <Button fx:id="btnChoiceDirForSave" mnemonicParsing="false" onAction="#btnChoiceDirForSaveImage" prefWidth="180.0" text="Directory for save">
                <tooltip>
                    <Tooltip text="Default directory: Desktop" />
                </tooltip>
            </Button>
        </HBox>

        <VBox alignment="CENTER" spacing="8.0">
            <Label fx:id="labelSuccess" alignment="CENTER" minHeight="20.0" prefHeight="20.0" prefWidth="800.0" styleClass="labelSuccess" text="Status: success" textFill="#32CD32" visible="false" wrapText="true" />

            <Button fx:id="btnSaveTag" mnemonicParsing="false" onAction="#submitAndDownload" prefWidth="240.0" text="Save Tags" />
        </VBox>

        <GridPane hgap="12.0" maxWidth="Infinity" minWidth="0" VBox.vgrow="ALWAYS">
            <padding>
                <Insets left="4.0" right="4.0"/>
            </padding>
            <VBox.margin>
                <Insets top="2.0"/>
            </VBox.margin>
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" minWidth="0" percentWidth="40.0"/>
                <ColumnConstraints hgrow="ALWAYS" minWidth="0" percentWidth="60.0"/>
            </columnConstraints>
            <rowConstraints>
                <RowConstraints vgrow="ALWAYS"/>
            </rowConstraints>
            <StackPane alignment="TOP_LEFT" minHeight="200.0" maxWidth="Infinity"
                       prefHeight="300.0"
                       style="-fx-border-color: white; -fx-border-style: solid; -fx-border-width: 2; -fx-border-radius: 10;"
                       GridPane.columnIndex="0">
                <padding>
                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                </padding>
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                            style="-fx-background-color: transparent; -fx-background: transparent;
                            -fx-border-color: transparent; -fx-padding: 0;">
                    <VBox spacing="10.0">
                        <VBox spacing="2.0">
                            <Label styleClass="labelTag" text="Title:" textFill="WHITE"/>
                            <TextField fx:id="titleField" styleClass="textFieldTag"/>
                        </VBox>
                        <VBox spacing="2.0">
                            <Label styleClass="labelTag" text="Artist:" textFill="WHITE"/>
                            <TextField fx:id="artistField" styleClass="textFieldTag"/>
                        </VBox>
                        <VBox spacing="2.0">
                            <Label styleClass="labelTag" text="Album:" textFill="WHITE"/>
                            <TextField fx:id="albumField" styleClass="textFieldTag"/>
                        </VBox>
                        <HBox spacing="10.0">
                            <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                <Label styleClass="labelTag" text="Album Artist:" textFill="WHITE"/>
                                <TextField fx:id="albumArtistField" styleClass="textFieldTag"/>
                            </VBox>
                            <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                <Label styleClass="labelTag" text="Composer:" textFill="WHITE"/>
                                <TextField fx:id="composerField" styleClass="textFieldTag"/>
                            </VBox>
                        </HBox>
                        <HBox spacing="10.0">
                            <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                <Label styleClass="labelTag" text="Track:" textFill="WHITE"/>
                                <TextField fx:id="trackField" prefHeight="25.0" prefWidth="30.0"
                                           styleClass="textFieldTag"/>
                            </VBox>
                            <VBox spacing="2.0">
                                <Label styleClass="labelTag" text="Year:" textFill="WHITE"/>
                                <TextField fx:id="yearField" styleClass="textFieldTag"
                                           prefHeight="25.0" prefWidth="82.0"/>
                            </VBox>
                            <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                <Label styleClass="labelTag" text="Genre:" textFill="WHITE"/>
                                <ComboBox fx:id="genreComboBox" maxWidth="Infinity"
                                          prefHeight="25.0" prefWidth="0.0"/>
                            </VBox>
                        </HBox>
                        <VBox spacing="2.0">
                            <Label styleClass="labelTag" text="Disc Number:" textFill="WHITE"/>
                            <TextField fx:id="discNumberField" styleClass="textFieldTag"/>
                        </VBox>
                        <VBox spacing="2.0">
                            <Label styleClass="labelTag" text="Comment:" textFill="WHITE"/>
                            <TextField fx:id="commentField" styleClass="textFieldTag"/>
                        </VBox>
                        <VBox maxWidth="Infinity">
                            <Button fx:id="btnChangeIcon" maxWidth="Infinity" mnemonicParsing="false"
                                    onAction="#onActionChangeIcon" text="Change Icon"/>
                        </VBox>
                        <HBox alignment="CENTER_LEFT">
                            <StackPane prefHeight="150.0" prefWidth="150.0"
                                       style="-fx-border-color: white; -fx-border-style: solid; -fx-border-width: 1; -fx-border-radius: 10;">
                                <ImageView fx:id="imageViewPreview" fitHeight="130.0"
                                           fitWidth="150.0" preserveRatio="true"
                                           StackPane.alignment="CENTER"/>
                            </StackPane>
                        </HBox>
                    </VBox>
                </ScrollPane>
            </StackPane>

            <VBox spacing="10.0" GridPane.columnIndex="1" maxWidth="Infinity" minWidth="0">
                <TextField fx:id="textFieldFindFile" promptText="Search"/>
                <HBox VBox.vgrow="ALWAYS">
                    <ScrollPane fx:id="tableScrollPane" fitToHeight="true" maxWidth="Infinity" minWidth="0"
                                vbarPolicy="NEVER" HBox.hgrow="ALWAYS"
                                style="-fx-padding: 0;">
                        <TableView fx:id="tableViewAudio" prefHeight="500.0" tableMenuButtonVisible="true">
                            <columns>
                                <TableColumn fx:id="colFileName" prefWidth="150" text="Filename"/>
                                <TableColumn fx:id="colPath" prefWidth="100" text="Path"/>
                                <TableColumn fx:id="colTag" prefWidth="70" text="Tag"/>
                                <TableColumn fx:id="colTitle" prefWidth="100" text="Title"/>
                                <TableColumn fx:id="colArtist" prefWidth="100" text="Artist"/>
                                <TableColumn fx:id="colAlbumArtist" prefWidth="100" text="AlbumArtist"/>
                                <TableColumn fx:id="colAlbum" prefWidth="100" text="Album"/>
                                <TableColumn fx:id="colTrack" prefWidth="50" text="Track"/>
                                <TableColumn fx:id="colDiscnumber" prefWidth="50" text="Discnumber"/>
                                <TableColumn fx:id="colYear" prefWidth="50" text="Year"/>
                                <TableColumn fx:id="colGenre" prefWidth="70" text="Genre"/>
                                <TableColumn fx:id="colComment" prefWidth="100" text="Comment"/>
                                <TableColumn fx:id="colCodec" prefWidth="70" text="Codec"/>
                                <TableColumn fx:id="colBitrate" prefWidth="70" text="Bitrate"/>
                                <TableColumn fx:id="colFrequency" prefWidth="70" text="Frequency"/>
                                <TableColumn fx:id="colLength" prefWidth="70" text="Length"/>
                                <TableColumn fx:id="colModified" prefWidth="70" text="Modified"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="UNCONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                            <cursor>
                                <Cursor fx:constant="DEFAULT"/>
                            </cursor>
                        </TableView>
                    </ScrollPane>
                    <ScrollBar fx:id="tableVerticalScrollBar" managed="false" maxWidth="14.0" minWidth="14.0"
                               orientation="VERTICAL" prefWidth="14.0" visible="false"/>
                </HBox>
                <StackPane fx:id="dropZone"

                           styleClass="drop-zone" VBox.vgrow="NEVER" minHeight="100.0">
                    <Label fx:id="textDragZone" text="Drag files here" textFill="WHITE" styleClass="label-drag-zone"/>
                </StackPane>
            </VBox>
        </GridPane>

        <VBox alignment="CENTER" spacing="4.0">
            <Label fx:id="labelSelectImageName" alignment="CENTER" minHeight="18.0" prefWidth="600.0" styleClass="labelSelect" text="Selected audio file: none" textFill="RED" wrapText="true" />

            <Button fx:id="btnReset" mnemonicParsing="false" onAction="#onResetPressed" prefWidth="240.0" text="Reset" />
        </VBox>

        <padding>
            <Insets bottom="16.0" left="16.0" right="16.0" top="8.0" />
        </padding>
    </VBox>

    <Button onAction="#showInfo" styleClass="info-button" text="?" StackPane.alignment="TOP_LEFT">
        <StackPane.margin>
            <Insets left="10.0" top="10.0" />
        </StackPane.margin>
    </Button>
</StackPane>
